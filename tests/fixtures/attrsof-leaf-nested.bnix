#lang beagle/nix
(ns modules.attrsof-leaf-nested-test)

(fn-set-rest (config lib pkgs)
  {:options.myConfig.modules.attrsof-leaf-nested-test.enable
     (lib/mkEnableOption "attrsOf str with nested attrset value (leaf scalar expected)")

   :config
     (lib/mkIf config.myConfig.modules.attrsof-leaf-nested-test.enable
       {
        :hardware.alsa.deviceAliases {:foo {:nested "x"}}})})
