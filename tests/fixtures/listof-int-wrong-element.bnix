#lang beagle/nix
(ns modules.listof-mismatch-test)

(fn-set-rest (config lib pkgs)
  {:options.myConfig.modules.listof-mismatch-test.enable
     (lib/mkEnableOption "listOf int containing strings")

   :config
     (lib/mkIf config.myConfig.modules.listof-mismatch-test.enable
       {
        :networking.firewall.allowedTCPPorts ["80" "443"]})})
