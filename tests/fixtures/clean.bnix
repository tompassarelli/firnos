#lang beagle/nix
(ns modules.clean-test)

(module (config lib pkgs)
  {:options.myConfig.modules.clean-test.enable
     (lib/mkEnableOption "all valid — should produce zero errors")

   :config
     (lib/mkIf config.myConfig.modules.clean-test.enable
       {
        :services.openssh.enable true
        :networking.firewall.allowedTCPPorts [80 443]
        :boot.loader.systemd-boot.consoleMode "auto"})})
