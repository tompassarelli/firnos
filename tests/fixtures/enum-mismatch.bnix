#lang beagle/nix
(ns modules.enum-mismatch-test)

(fn-set-rest (config lib pkgs)
  {:options.myConfig.modules.enum-mismatch-test.enable
     (lib/mkEnableOption "enum value not in allowed set, with near-miss for did-you-mean")

   :config
     (lib/mkIf config.myConfig.modules.enum-mismatch-test.enable
       {
        :boot.loader.systemd-boot.consoleMode "atuo"})})
