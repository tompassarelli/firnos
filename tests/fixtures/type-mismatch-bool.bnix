#lang beagle/nix
(ns modules.type-mismatch-bool-test)

(module (config lib pkgs)
  {:options.myConfig.modules.type-mismatch-bool-test.enable
     (lib/mkEnableOption "bool option with string value")

   :config
     (lib/mkIf config.myConfig.modules.type-mismatch-bool-test.enable
       {
        :services.openssh.enable "yes"})})
