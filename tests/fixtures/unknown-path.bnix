#lang beagle/nix
(ns modules.unknown-path-test)

(fn-set-rest (config lib pkgs)
  {:options.myConfig.modules.unknown-path-test.enable
     (lib/mkEnableOption "intentional unknown option")

   :config
     (lib/mkIf config.myConfig.modules.unknown-path-test.enable
       {
        :services.pipwire.alsa.enable true})})
