#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.bundles.javascript
    {:enable        (lib.mkEnableOption "JavaScript / Node.js development")
     :nodejs.enable
      (lib.mkOption
        {:type lib.types.bool :default true :description "Enable nodejs"})}
   :config
    (lib.mkIf config.myConfig.bundles.javascript.enable
      {:myConfig.modules.nodejs.enable
        (lib.mkDefault config.myConfig.bundles.javascript.nodejs.enable)})})
