#lang beagle/nix
(ns bundles.python)

(module [config lib pkgs]
  {:options.myConfig.bundles.python.enable
     (lib/mkEnableOption "Python development (python3 + uv)")

   :config
     (lib/mkIf config.myConfig.bundles.python.enable
       {
        :myConfig.modules.python.enable (lib/mkDefault true)
        :myConfig.modules.uv.enable (lib/mkDefault true)})})
