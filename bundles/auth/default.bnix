#lang beagle/nix
(ns bundles.auth)

(module [config lib pkgs]
  {:options.myConfig.bundles.auth.enable
     (lib/mkEnableOption "authentication (polkit + GNOME Keyring)")

   :config
     (lib/mkIf config.myConfig.bundles.auth.enable
       {
        :myConfig.modules.polkit.enable (lib/mkDefault true)
        :myConfig.modules.gnome-keyring.enable (lib/mkDefault true)})})
