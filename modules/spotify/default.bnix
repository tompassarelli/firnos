#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [media]
   :options.myConfig.modules.spotify.enable
    (lib.mkEnableOption "Spotify TUI player")
   :config
    (lib.mkIf config.myConfig.modules.spotify.enable
      {:environment.systemPackages (nix/with pkgs [spotify])})})
