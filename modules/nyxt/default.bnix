#lang beagle/nix
(ns modules.nyxt)

(module [config lib pkgs]
  {:options.myConfig.modules.nyxt
     {:enable (lib/mkEnableOption "Enable Nyxt browser")
      :default (lib/mkOption {:type lib/types.bool :description "Set Nyxt as the default browser via MIME types"})}

   :imports [(p "./nyxt.nix")]

   :config
     (lib/mkIf config.myConfig.modules.nyxt.enable
       {})})
