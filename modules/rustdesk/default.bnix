#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.modules.rustdesk.enable
    (lib.mkEnableOption "RustDesk remote desktop")
   :config
    (lib.mkIf config.myConfig.modules.rustdesk.enable
      {:environment.systemPackages (nix/with pkgs [rustdesk-flutter])})})
