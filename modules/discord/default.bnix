#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [communication]
   :options.myConfig.modules.discord.enable
    (lib.mkEnableOption "Discord chat client")
   :config
    (lib.mkIf config.myConfig.modules.discord.enable
      {:environment.systemPackages (nix/with pkgs [discord])})})
