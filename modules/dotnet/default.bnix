#lang beagle/nix

(ns default)

(module [config lib pkgs ...]
        {:options.myConfig.modules.dotnet.enable
         (lib.mkEnableOption ".NET SDK and CLI tools")
         :config
         (lib.mkIf config.myConfig.modules.dotnet.enable
                   {:environment.systemPackages
                    (with pkgs [dotnet-sdk_8])
                    :environment.sessionVariables.PATH
                    ["$HOME/.dotnet/tools"]})})
