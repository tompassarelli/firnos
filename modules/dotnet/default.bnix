#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [csharp]
   :options.myConfig.modules.dotnet.enable
    (lib.mkEnableOption ".NET SDK and CLI tools")
   :config
    (lib.mkIf config.myConfig.modules.dotnet.enable
      {:environment.systemPackages (nix/with pkgs [dotnet-sdk_8])
       :environment.sessionVariables.PATH ["$HOME/.dotnet/tools"]})})
