#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.modules.gutenprint.enable
    (lib.mkEnableOption "Gutenprint printer drivers")
   :config
    (lib.mkIf config.myConfig.modules.gutenprint.enable
      {:services.printing.drivers (nix/with pkgs [gutenprint])})})
