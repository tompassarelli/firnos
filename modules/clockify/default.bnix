#lang beagle/nix
(ns modules.clockify)

(module [config lib flakeRoot]
  (let [username config.myConfig.modules.users.username]
  {:options.myConfig.modules.clockify.enable
     (lib/mkEnableOption "clockify")

   :config
     (lib/mkIf config.myConfig.modules.clockify.enable
       {:sops.secrets
        {"msa-clockify-api-key"
           {:sopsFile (s flakeRoot "/secrets/clockify.yaml")
            :owner username}}})}))
