#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [cli-tools]
   :options.myConfig.modules.btop.enable
    (lib.mkEnableOption "Enable btop system monitor")
   :config
    (lib.mkIf config.myConfig.modules.btop.enable
      {:environment.systemPackages (nix/with pkgs [btop])})})
