#lang beagle/nix

(ns default)

(module (params config lib pkgs ...)
        {:options.myConfig.modules.freetds.enable
         (lib.mkEnableOption "FreeTDS (TDS protocol library for MSSQL)")
         :config
         (lib.mkIf config.myConfig.modules.freetds.enable
                   {:environment.systemPackages (with pkgs [freetds])})})
