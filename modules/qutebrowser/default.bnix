#lang beagle/nix
(ns modules.qutebrowser)

(module [config lib pkgs]
  {:options.myConfig.modules.qutebrowser
     {:enable (lib/mkEnableOption "Enable Qutebrowser")
      :default (lib/mkOption {:type lib/types.bool :description "Set Qutebrowser as the default browser via MIME types"})}

   :imports [(p "./qutebrowser.nix")]

   :config
     (lib/mkIf config.myConfig.modules.qutebrowser.enable
       {})})
