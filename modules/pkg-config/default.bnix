#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [rust]
   :options.myConfig.modules.pkg-config.enable
    (lib.mkEnableOption "pkg-config build tool")
   :config
    (lib.mkIf config.myConfig.modules.pkg-config.enable
      {:environment.systemPackages (nix/with pkgs [pkg-config])})})
