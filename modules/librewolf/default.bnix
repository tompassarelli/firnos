#lang beagle/nix
(ns modules.librewolf)

(module [config lib pkgs]
  {:options.myConfig.modules.librewolf
     {:enable (lib/mkEnableOption "Enable LibreWolf browser")
      :default (lib/mkOption {:type lib/types.bool :description "Set LibreWolf as the default browser via MIME types"})}

   :imports [(p "./librewolf.nix")]

   :config
     (lib/mkIf config.myConfig.modules.librewolf.enable
       {})})
