#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.modules.obs-studio.enable
    (lib.mkEnableOption "OBS Studio screen recording")
   :config
    (lib.mkIf config.myConfig.modules.obs-studio.enable
      {:environment.systemPackages (nix/with pkgs [obs-studio])})})
