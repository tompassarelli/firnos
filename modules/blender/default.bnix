#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [creative]
   :options.myConfig.modules.blender.enable
    (lib.mkEnableOption "Blender 3D editor")
   :config
    (lib.mkIf config.myConfig.modules.blender.enable
      {:environment.systemPackages (nix/with pkgs [blender])})})
