#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [development]
   :options.myConfig.modules.delta.enable
    (lib.mkEnableOption "delta git diff viewer")
   :config
    (lib.mkIf config.myConfig.modules.delta.enable
      {:environment.systemPackages (nix/with pkgs [delta])})})
