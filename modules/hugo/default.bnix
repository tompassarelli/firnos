#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [productivity]
   :options.myConfig.modules.hugo.enable
    (lib.mkEnableOption "Hugo static site generator")
   :config
    (lib.mkIf config.myConfig.modules.hugo.enable
      {:environment.systemPackages (nix/with pkgs [hugo])})})
