#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [productivity]
   :options.myConfig.modules.pomodoro.enable
    (lib.mkEnableOption "Pomodoro timer")
   :config
    (lib.mkIf config.myConfig.modules.pomodoro.enable
      {:environment.systemPackages (nix/with pkgs [pomodoro-gtk])})})
