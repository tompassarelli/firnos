#lang beagle/nix

(ns default)

(module (params config lib pkgs ...)
        {:options.myConfig.modules.libtool.enable
         (lib.mkEnableOption "GNU Libtool")
         :config
         (lib.mkIf config.myConfig.modules.libtool.enable
                   {:environment.systemPackages (with pkgs [libtool])})})
