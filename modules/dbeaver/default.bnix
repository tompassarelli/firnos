#lang beagle/nix

(ns default)

(module [config lib pkgs ...]
        {:options.myConfig.modules.dbeaver.enable
         (lib.mkEnableOption "DBeaver database GUI")
         :config
         (lib.mkIf config.myConfig.modules.dbeaver.enable
                   {:environment.systemPackages (with pkgs [dbeaver-bin])})})
