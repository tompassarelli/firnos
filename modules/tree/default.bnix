#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [cli-tools]
   :options.myConfig.modules.tree.enable
    (lib.mkEnableOption "Enable tree file tree display utility")
   :config
    (lib.mkIf config.myConfig.modules.tree.enable
      {:environment.systemPackages (nix/with pkgs [tree])})})
