#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [communication]
   :options.myConfig.modules.slack.enable
    (lib.mkEnableOption "Slack messaging")
   :config
    (lib.mkIf config.myConfig.modules.slack.enable
      {:environment.systemPackages (nix/with pkgs [slack])})})
