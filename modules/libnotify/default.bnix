#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.modules.libnotify.enable
    (lib.mkEnableOption "libnotify notification client")
   :config
    (lib.mkIf config.myConfig.modules.libnotify.enable
      {:environment.systemPackages (nix/with pkgs [libnotify])})})
