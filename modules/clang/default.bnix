#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [doom-emacs]
   :options.myConfig.modules.clang.enable
    (lib.mkEnableOption "Clang C/C++ compiler")
   :config
    (lib.mkIf config.myConfig.modules.clang.enable
      {:environment.systemPackages (nix/with pkgs [clang])})})
