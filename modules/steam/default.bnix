#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [gaming]
   :options.myConfig.modules.steam.enable
    (lib.mkEnableOption "Steam gaming platform")
   :config
    (lib.mkIf config.myConfig.modules.steam.enable
      {:programs.steam {:enable true :package pkgs.unstable.steam}})})
