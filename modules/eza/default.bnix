#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [cli-tools]
   :options.myConfig.modules.eza.enable
    (lib.mkEnableOption "Enable eza (modern ls replacement)")
   :config
    (lib.mkIf config.myConfig.modules.eza.enable
      {:environment.systemPackages (nix/with pkgs [eza])})})
