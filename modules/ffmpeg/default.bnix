#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [desktop]
   :options.myConfig.modules.ffmpeg.enable
    (lib.mkEnableOption "FFmpeg video processing")
   :config
    (lib.mkIf config.myConfig.modules.ffmpeg.enable
      {:environment.systemPackages (nix/with pkgs [ffmpeg])})})
