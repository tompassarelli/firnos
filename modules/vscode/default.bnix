#lang beagle/nix

(ns default)

(module (params config lib pkgs ...)
        {:options.myConfig.modules.vscode.enable
         (lib.mkEnableOption "Visual Studio Code (Microsoft build)")
         :config
         (lib.mkIf config.myConfig.modules.vscode.enable
                   {:environment.systemPackages [pkgs.unstable.vscode]})})
