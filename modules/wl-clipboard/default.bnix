#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [desktop]
   :options.myConfig.modules.wl-clipboard.enable
    (lib.mkEnableOption "Wayland clipboard utilities")
   :config
    (lib.mkIf config.myConfig.modules.wl-clipboard.enable
      {:environment.systemPackages (nix/with pkgs [wl-clipboard])})})
