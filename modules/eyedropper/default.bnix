#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [desktop]
   :options.myConfig.modules.eyedropper.enable
    (lib.mkEnableOption "Wayland color picker")
   :config
    (lib.mkIf config.myConfig.modules.eyedropper.enable
      {:environment.systemPackages (nix/with pkgs [eyedropper])})})
