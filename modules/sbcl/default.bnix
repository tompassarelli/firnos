#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [doom-emacs lisp]
   :options.myConfig.modules.sbcl.enable
    (lib.mkEnableOption "Steel Bank Common Lisp compiler")
   :config
    (lib.mkIf config.myConfig.modules.sbcl.enable
      {:environment.systemPackages (nix/with pkgs [sbcl])})})
