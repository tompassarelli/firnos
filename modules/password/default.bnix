#lang beagle/nix
(ns modules.password)

(module [config lib pkgs]
  {:options.myConfig.modules.password.enable
     (lib/mkEnableOption "password management tools")

   :config
     (lib/mkIf config.myConfig.modules.password.enable
       {
        :environment.systemPackages (with-do pkgs [bitwarden-desktop])})})
