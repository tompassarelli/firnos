#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [doom-emacs]
   :options.myConfig.modules.shellcheck.enable
    (lib.mkEnableOption "ShellCheck shell script linter")
   :config
    (lib.mkIf config.myConfig.modules.shellcheck.enable
      {:environment.systemPackages (nix/with pkgs [shellcheck])})})
