#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [doom-emacs]
   :options.myConfig.modules.emacs.enable
    (lib.mkEnableOption "GNU Emacs editor")
   :config
    (lib.mkIf config.myConfig.modules.emacs.enable
      {:environment.systemPackages (nix/with pkgs [emacs-pgtk])})})
