#lang beagle/nix
(ns modules.zen-browser)

(module [config lib pkgs]
  {:options.myConfig.modules.zen-browser
     {:enable (lib/mkEnableOption "Enable Zen Browser")
      :default (lib/mkOption {:type lib/types.bool :description "Set Zen Browser as the default browser via MIME types"})}

   :imports [(p "./zen-browser.nix")]

   :config
     (lib/mkIf config.myConfig.modules.zen-browser.enable
       {})})
