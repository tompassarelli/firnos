#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags-opt-in [browsers]
   :options.myConfig.modules.zen-browser.enable
    (lib.mkEnableOption "Enable Zen Browser")
   :options.myConfig.modules.zen-browser.default
    (lib.mkOption
      {:type        lib.types.bool
       :default     false
       :description "Set Zen Browser as the default browser via MIME types"})
   :imports [(p "./zen-browser.nix")]})
