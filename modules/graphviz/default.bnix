#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [doom-emacs]
   :options.myConfig.modules.graphviz.enable
    (lib.mkEnableOption "Graphviz graph visualization")
   :config
    (lib.mkIf config.myConfig.modules.graphviz.enable
      {:environment.systemPackages (nix/with pkgs [graphviz])})})
