#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.modules.piper.enable
    (lib.mkEnableOption "gaming mouse configuration (Piper + ratbagd)")
   :config
    (lib.mkIf config.myConfig.modules.piper.enable
      {:services.ratbagd.enable true
       :environment.systemPackages (nix/with pkgs [piper])})})
