#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [productivity]
   :options.myConfig.modules.anytype.enable
    (lib.mkEnableOption "Anytype — local-first knowledge/notes workspace")
   :config
    (lib.mkIf config.myConfig.modules.anytype.enable
      {:environment.systemPackages (nix/with pkgs [anytype])})})
