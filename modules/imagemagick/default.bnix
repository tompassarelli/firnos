#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [cli-tools]
   :options.myConfig.modules.imagemagick.enable
    (lib.mkEnableOption "ImageMagick image processing")
   :config
    (lib.mkIf config.myConfig.modules.imagemagick.enable
      {:environment.systemPackages (nix/with pkgs [imagemagick])})})
