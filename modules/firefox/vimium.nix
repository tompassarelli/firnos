# Vimium key mappings
# Paste into Vimium options > Custom key mappings
#
# map h goBack
# map l goForward
# map H scrollLeft
# map L scrollRight
# map <c-l> Vomnibar.activate
# map <c-L> Vomnibar.activateInNewTab
# map ^ Marks.activateGotoMode
# map ` visitPreviousTab
# map K previousTab
# map J nextTab
# map T createTab
# map t Vomnibar.activateTabSelection
