#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.modules.ghostscript.enable
    (lib.mkEnableOption "Ghostscript PostScript interpreter")
   :config
    (lib.mkIf config.myConfig.modules.ghostscript.enable
      {:environment.systemPackages (nix/with pkgs [ghostscript])})})
