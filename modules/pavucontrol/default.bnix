#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [desktop]
   :options.myConfig.modules.pavucontrol.enable
    (lib.mkEnableOption "PulseAudio volume control")
   :config
    (lib.mkIf config.myConfig.modules.pavucontrol.enable
      {:environment.systemPackages (nix/with pkgs [pavucontrol])})})
