#lang beagle/nix

(ns default)

(module [config lib pkgs ...]
  {:options.myConfig.modules.pipewire.enable
    (lib.mkEnableOption "PipeWire audio configuration")
   :config
    (lib.mkIf config.myConfig.modules.pipewire.enable
      {:services.pipewire
        {:enable true
         :pulse.enable true
         :alsa.enable true
         :alsa.support32Bit true}})})
