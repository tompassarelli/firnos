#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [cli-tools]
   :options.myConfig.modules.procs.enable
    (lib.mkEnableOption "Enable procs (modern ps replacement)")
   :config
    (lib.mkIf config.myConfig.modules.procs.enable
      {:environment.systemPackages (nix/with pkgs [procs])})})
