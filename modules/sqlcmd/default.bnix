#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [csharp]
   :options.myConfig.modules.sqlcmd.enable
    (lib.mkEnableOption "sqlcmd for Microsoft SQL Server")
   :config
    (lib.mkIf config.myConfig.modules.sqlcmd.enable
      {:environment.systemPackages [pkgs.sqlcmd]})})
