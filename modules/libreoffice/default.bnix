#lang beagle/nix

(ns default)

(module [config lib pkgs ...]
  {:options.myConfig.modules.libreoffice.enable
    (lib.mkEnableOption "Enable LibreOffice office suite")
   :config
    (lib.mkIf config.myConfig.modules.libreoffice.enable
      {:environment.systemPackages (nix/with pkgs [libreoffice-fresh])})})
