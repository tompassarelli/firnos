#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [printing]
   :options.myConfig.modules.printing.enable
    (lib.mkEnableOption "CUPS printing service with network discovery")
   :config
    (lib.mkIf config.myConfig.modules.printing.enable
      {:services.printing.enable true
       :services.avahi {:enable true :nssmdns4 true :openFirewall true}})})
