#lang beagle/nix
(ns modules.babashka)

(module [config lib pkgs]
  {:options.myConfig.modules.babashka.enable
     (lib/mkEnableOption "Babashka native Clojure scripting")

   :config
     (lib/mkIf config.myConfig.modules.babashka.enable
       {:environment.systemPackages (with pkgs [babashka])})})
