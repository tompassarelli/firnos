#lang beagle/nix
(ns containers.devshell-flake)

{:description "Dev sandbox environment"

 :inputs {:nixpkgs.url "github:nixos/nixpkgs/nixos-unstable"}

 :outputs
   (fn-set (nixpkgs)
     (let [system "x86_64-linux"
           pkgs (builtins.getAttr system nixpkgs.legacyPackages)]
       {:devShells
          {system
            {:default
              (pkgs.mkShell
                {:packages (with pkgs [])})}}}))}
