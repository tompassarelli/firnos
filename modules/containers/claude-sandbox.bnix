#lang beagle/nix
(ns containers.claude-sandbox)

;; Top-level: a function {pkgs}: <derivation> producing the docker image.
;; Imported from flake.bnix as a flake package output, not as a NixOS module.
;; Path-interpolations (./devshell-flake.nix, ./CLAUDE.md) use (p "./...")
;; which beagle/nix resolves to Nix path values; ${...} in the multi-line
;; string converts them to store paths at eval time.

(fn-set (pkgs)
  (pkgs.dockerTools.buildLayeredImage
    {:name "claude-sandbox"
     :tag  "latest"

     :contents (with pkgs
                 [bashInteractive coreutils gnused gnugrep findutils gawk
                  less which gnutar gzip xz
                  git gh openssh
                  nix
                  claude-code
                  nodejs python3 ripgrep fd curl jq])

     :extraCommands
     (ms "mkdir -p home/dev/.claude"
         "mkdir -p home/dev/.config/nix"
         "mkdir -p work"
         "mkdir -p tmp"
         "chmod 1777 tmp"
         "mkdir -p nix/var/nix/{profiles,gcroots,db}"
         "mkdir -p etc"
         "echo \"dev:x:1000:1000::/home/dev:/bin/bash\" > etc/passwd"
         "echo \"dev:x:1000:\" > etc/group"
         "# Enable flakes and nix-command in container"
         "echo \"experimental-features = nix-command flakes\" > home/dev/.config/nix/nix.conf"
         "# Starter flake for declarative package management"
         (s "cp " (p "./devshell-flake.nix") " home/dev/flake.nix")
         "chmod 644 home/dev/flake.nix"
         "# Instructions for Claude Code"
         (s "cp " (p "./CLAUDE.md") " work/CLAUDE.md")
         "chmod 644 work/CLAUDE.md")

     :config
     {:Cmd        ["/bin/bash"]
      :WorkingDir "/work"
      :User       "dev"
      :Env        ["HOME=/home/dev"
                   "USER=dev"
                   (s "SSL_CERT_FILE=" pkgs.cacert "/etc/ssl/certs/ca-bundle.crt")
                   "NIX_CONF_DIR=/home/dev/.config/nix"]}}))
