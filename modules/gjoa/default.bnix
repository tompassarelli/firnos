#lang beagle/nix
(ns modules.gjoa)

(module [config lib pkgs]
  {:options.myConfig.modules.gjoa
     {:enable (lib/mkEnableOption "Gjoa — a Firefox fork. Wrapped via wrapFirefox; appears in launchers/drun.")
      :default (lib/mkOption {:type lib/types.bool :description "Set Gjoa as the default browser via MIME types"})}

   :imports [(p "./gjoa.nix")]

   :config
     (lib/mkIf config.myConfig.modules.gjoa.enable
       {})})
