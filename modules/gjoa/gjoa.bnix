#lang beagle/nix
(ns gjoa.gjoa)

(module [config lib pkgs inputs]
  {:config (lib/mkIf config.myConfig.modules.gjoa.enable {:environment.systemPackages [(flake-input :gjoa :packages :gjoa)] :xdg.mime.defaultApplications (lib/mkIf config.myConfig.modules.gjoa.default {"text/html" "gjoa.desktop" "x-scheme-handler/http" "gjoa.desktop" "x-scheme-handler/https" "gjoa.desktop" "x-scheme-handler/about" "gjoa.desktop" "x-scheme-handler/unknown" "gjoa.desktop"})})})
