#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [cli-tools]
   :options.myConfig.modules.dust.enable
    (lib.mkEnableOption "Enable dust disk usage analyzer")
   :config
    (lib.mkIf config.myConfig.modules.dust.enable
      {:environment.systemPackages (nix/with pkgs [dust])})})
