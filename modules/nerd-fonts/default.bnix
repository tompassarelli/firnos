#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:tags [doom-emacs theming]
   :options.myConfig.modules.nerd-fonts.enable
    (lib.mkEnableOption "Nerd Fonts symbols")
   :config
    (lib.mkIf config.myConfig.modules.nerd-fonts.enable
      {:fonts.packages [pkgs.nerd-fonts.symbols-only]})})
