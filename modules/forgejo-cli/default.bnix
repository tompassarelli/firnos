#lang beagle/nix

(ns default)

(nix/module [config lib pkgs ...]
  {:options.myConfig.modules.forgejo-cli.enable
    (lib.mkEnableOption
      "Forgejo CLI for repo / issue / CI ops against codeberg + other Forgejo instances")
   :config
    (lib.mkIf config.myConfig.modules.forgejo-cli.enable
      {:environment.systemPackages (nix/with pkgs [forgejo-cli])})})
