#!/usr/bin/env bash
# firn-extract-schema — thin wrapper around `beagle-extract-schema`.
#
# Configures the extractor for this repo:
#   target: nixosConfigurations.$HOST.options  (default HOST: whiterabbit)
#   out:    .nisp-cache/schema.json
#
# Usage:
#   firn-extract-schema [host]                    # NixOS (default)
#   firn-extract-schema --darwin [host]           # nix-darwin (default host: ashashi)

set -euo pipefail

REPO="${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
BEAGLE_PATH="${BEAGLE_PATH:-$(cd "$REPO/.." && pwd)/beagle}"
BEAGLE_EXTRACT="$BEAGLE_PATH/bin/beagle-extract-schema"

DARWIN=false
if [[ "${1:-}" == "--darwin" ]]; then
  DARWIN=true
  shift
fi

if $DARWIN; then
  HOST="${1:-ashashi}"
  TARGET="darwinConfigurations.$HOST.options"
  OUT="$REPO/.nisp-cache/schema-darwin.json"
else
  HOST="${1:-whiterabbit}"
  TARGET="nixosConfigurations.$HOST.options"
  OUT="$REPO/.nisp-cache/schema.json"
fi

if [[ ! -x "$BEAGLE_EXTRACT" ]]; then
  echo "firn-extract-schema: beagle-extract-schema not found at $BEAGLE_EXTRACT" >&2
  echo "  clone beagle: git clone https://github.com/tompassarelli/beagle \"$BEAGLE_PATH\"" >&2
  echo "  or set BEAGLE_PATH=/path/to/beagle" >&2
  exit 2
fi

exec "$BEAGLE_EXTRACT" \
  --target "$TARGET" \
  --out "$OUT" \
  --flake "$REPO"
