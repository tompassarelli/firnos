#!/usr/bin/env bash
# firn-extract-schema — dump every NixOS option (path + type info) into
# .firn-build/schema.json. Includes custom myConfig.* options + flake-input
# options (stylix, home-manager, sops, etc.) automatically.
#
# Each entry has:
#   p     - dotted option path
#   t     - top-level type name ("bool", "str", "listOf", "nullOr", "enum", ...)
#   inner - (optional) recursive {t, inner?, enum?} for parameterized types
#   enum  - (optional) list of valid values for enum types
#
# Re-run after `nix flake update` or after adding/changing modules with
# new options. Cached output is read by firn-validate.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

mkdir -p .firn-build

# Pick the host whose options-tree we use as the schema. Whiterabbit's tree
# already includes everything this repo touches.
HOST="${1:-whiterabbit}"

echo "firn-extract-schema: extracting options tree for nixosConfigurations.${HOST}..."

nix eval --json --impure --expr "
let
  flake = builtins.getFlake (toString ./.);
  opts  = flake.nixosConfigurations.${HOST}.options;

  # Recursively describe a type. Captures the type-name, recurses into
  # nestedTypes.elemType for parameterized containers (listOf, nullOr,
  # attrsOf, lazyAttrsOf), and pulls enum values out of functor.payload.
  describeType = t:
    let
      base = { t = t.name or \"?\"; };
      tryInner =
        if (t ? nestedTypes) && (t.nestedTypes ? elemType)
        then builtins.tryEval (describeType t.nestedTypes.elemType)
        else { success = false; value = null; };
      withInner =
        if tryInner.success then base // { inner = tryInner.value; } else base;
      tryEnum =
        if (t.name or \"\") == \"enum\" && (t ? functor) && (t.functor ? payload) && (t.functor.payload ? values)
        then builtins.tryEval t.functor.payload.values
        else { success = false; value = null; };
      withEnum =
        if tryEnum.success then withInner // { enum = tryEnum.value; } else withInner;
    in withEnum;

  # Top-level walk only — does NOT expand submodule contents. Submodule
  # expansion is lazy: firn-validate triggers it on-demand for paths that
  # actually appear in the user's .rkt sources, caches results in
  # .firn-build/schema-submodules.json. This keeps the base schema dump
  # cheap (most submodule trees in nixpkgs go unused).
  walk = path: o:
    if (o._type or null) == \"option\"
    then [ ({ p = path; } // describeType (o.type or {})) ]
    else if builtins.isAttrs o
    then builtins.concatLists
      (builtins.attrValues
        (builtins.mapAttrs (n: v: walk (if path == \"\" then n else \"\${path}.\${n}\") v) o))
    else [];
in walk \"\" opts
" > .firn-build/schema.json 2>.firn-build/schema.err

count=$(python3 -c 'import json; print(len(json.load(open(".firn-build/schema.json"))))')
size=$(wc -c < .firn-build/schema.json)

echo "firn-extract-schema: cached $count option paths ($size bytes) → .firn-build/schema.json"
