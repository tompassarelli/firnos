#!/usr/bin/env bash
# firn-extract-schema — thin wrapper around nisp-extract-schema.
#
# Configures the extractor for this repo:
#   target: nixosConfigurations.$1.options  (default $1: whiterabbit)
#   out:    .nisp-cache/schema.json

set -euo pipefail

REPO="$(git rev-parse --show-toplevel)"
NISP_PATH="${NISP_PATH:-$(cd "$REPO/.." && pwd)/nisp}"

HOST="${1:-whiterabbit}"

if [[ ! -x "$NISP_PATH/bin/nisp-extract-schema" ]]; then
  echo "firn-extract-schema: nisp-extract-schema not found at $NISP_PATH/bin/nisp-extract-schema" >&2
  echo "  clone nisp: git clone https://github.com/tompassarelli/nisp \"$NISP_PATH\"" >&2
  echo "  or set NISP_PATH=/path/to/nisp" >&2
  exit 2
fi

exec "$NISP_PATH/bin/nisp-extract-schema" \
  --target "nixosConfigurations.$HOST.options" \
  --out "$REPO/.nisp-cache/schema.json" \
  --flake "$REPO"
