#!/usr/bin/env bash
# firn-verify — oracle for beagle's repair pipeline (beagle-repair,
# beagle-specfix, etc.). Returns 0 if the touched source validates clean,
# non-zero with diagnostic output otherwise.
#
# Default (fast, sub-second): schema-validate .bnix sources via beagle-validate.
# The repair pipeline calls this after each speculative fix; it must return
# in tens of milliseconds, not minutes.
#
#   beagle-repair . scripts/firn-verify --auto --threshold 0.85
#   beagle-specfix . scripts/firn-verify
#   scripts/firn-verify path/to/touched.bnix   # scoped to one file
#
# Opt-in slow path (--eval): regen .nix via firn-build, syntax-check the
# generated .nix via firn-lint-nix, then nix build. Use this only when
# chasing codegen bugs or pre-flighting a real system build — never as
# the per-fix oracle.
#
#   scripts/firn-verify --eval               # full slow rung
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO"

if [[ "${1:-}" == "--eval" ]]; then
  shift
  if ! ./scripts/firn-build >/dev/null 2>&1; then
    echo "firn-verify: firn-build failed" >&2
    ./scripts/firn-build 2>&1 | tail -10 >&2
    exit 1
  fi
  if ! ./scripts/firn-lint-nix >/dev/null 2>&1; then
    echo "firn-verify: firn-lint-nix failed (codegen bug?)" >&2
    ./scripts/firn-lint-nix 2>&1 | tail -20 >&2
    exit 1
  fi
  if ! nix build .#nixosConfigurations.whiterabbit.config.system.build.toplevel \
       --no-link --quiet 2>&1; then
    echo "firn-verify: nix build failed" >&2
    exit 1
  fi
fi

BEAGLE_PATH="${BEAGLE_PATH:-$(cd "$REPO/.." && pwd)/beagle}"
BEAGLE_VALIDATE="$BEAGLE_PATH/bin/beagle-validate"

if [[ ! -x "$BEAGLE_VALIDATE" ]]; then
  echo "firn-verify: beagle-validate not found at $BEAGLE_VALIDATE" >&2
  exit 2
fi

# If caller passed files, scope to those. Otherwise validate the whole tree
# (excluding intentionally-broken test fixtures).
if (( $# > 0 )); then
  exec "$BEAGLE_VALIDATE" "$@"
else
  mapfile -t FILES < <(find . -type f -name '*.bnix' \
    -not -path './tests/fixtures/*' \
    -not -path './result/*' \
    -not -path './.direnv/*' | sort)
  exec "$BEAGLE_VALIDATE" "${FILES[@]}"
fi
