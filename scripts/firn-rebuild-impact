#!/usr/bin/env bash
# firn-rebuild-impact — predict rebuild cost via nix build --dry-run.
#
# Shows what derivations need building vs fetching from cache, and
# flags known-expensive packages (firefox, chromium, kernel, etc.)
# with approximate wall-time estimates.
#
# Exit codes:
#   0 — impact printed (or system up to date)
#   1 — dry-run failed (eval error, etc.)

set -euo pipefail

REPO="${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
HOST="${1:-whiterabbit}"

# Check if host needs --impure (same logic as rebuild.rkt)
IMPURE_FLAG=""
HOST_NIX="$REPO/hosts/$HOST/configuration.nix"
if [[ -f "$HOST_NIX" ]]; then
  if grep -qE '(myConfig\.modules\.gjoa\.enable|[[:space:];{]gjoa\.enable)[[:space:]]*=[[:space:]]*true' "$HOST_NIX"; then
    IMPURE_FLAG="--impure"
  fi
fi

FLAKE_REF="$REPO#nixosConfigurations.$HOST.config.system.build.toplevel"

# Run dry-run, capturing stderr (that's where nix prints the plan)
DRY_OUTPUT=""
if ! DRY_OUTPUT=$(nix build "$FLAKE_REF" --dry-run $IMPURE_FLAG 2>&1); then
  echo "firn-rebuild-impact: dry-run failed (eval error?)" >&2
  echo "$DRY_OUTPUT" | tail -5 >&2
  exit 1
fi

# Parse derivations to build
TO_BUILD=()
TO_FETCH=()
SECTION=""

while IFS= read -r line; do
  if [[ "$line" =~ "these "([0-9]+)" derivations will be built" ]] || \
     [[ "$line" =~ "will be built:" ]]; then
    SECTION="build"
    continue
  elif [[ "$line" =~ "these paths will be fetched" ]] || \
       [[ "$line" =~ "will be fetched" ]]; then
    SECTION="fetch"
    continue
  elif [[ -z "$line" ]]; then
    SECTION=""
    continue
  fi

  # Store path lines start with /nix/store/ (possibly indented)
  cleaned="${line#"${line%%[![:space:]]*}"}"  # trim leading whitespace
  if [[ "$cleaned" == /nix/store/* ]]; then
    if [[ "$SECTION" == "build" ]]; then
      TO_BUILD+=("$cleaned")
    elif [[ "$SECTION" == "fetch" ]]; then
      TO_FETCH+=("$cleaned")
    fi
  fi
done <<< "$DRY_OUTPUT"

BUILD_COUNT=${#TO_BUILD[@]}
FETCH_COUNT=${#TO_FETCH[@]}

# If nothing to do
if [[ $BUILD_COUNT -eq 0 && $FETCH_COUNT -eq 0 ]]; then
  echo "Rebuild impact ($HOST):"
  echo "  System is up to date — nothing to build or fetch."
  exit 0
fi

# Extract human-readable names from store paths
# /nix/store/hash-name-version.drv -> name-version
extract_name() {
  local path="$1"
  local basename="${path##*/}"         # strip directory
  basename="${basename%.drv}"          # strip .drv suffix
  basename="${basename#*-}"            # strip hash prefix (32 chars + dash)
  echo "$basename"
}

# Known-expensive packages: pattern -> estimate
declare -A EXPENSIVE_PATTERNS=(
  ["firefox"]="~30-45 min"
  ["librewolf"]="~30-45 min"
  ["chromium"]="~60 min"
  ["linux-[0-9]"]="~15-20 min"
  ["ghc-"]="~30 min"
  ["llvm-"]="~20 min"
  ["clang-"]="~20 min"
  ["rustc-"]="~20 min"
  ["rust-"]="~20 min"
  ["nodejs-"]="~5 min"
  ["qt6-"]="~15 min"
  ["webkit"]="~30 min"
)

# Categorize builds
NOTABLE_BUILDS=()
MINOR_BUILDS=()

for path in "${TO_BUILD[@]}"; do
  name=$(extract_name "$path")
  matched=false
  for pattern in "${!EXPENSIVE_PATTERNS[@]}"; do
    if [[ "$name" =~ $pattern ]]; then
      NOTABLE_BUILDS+=("$name (${EXPENSIVE_PATTERNS[$pattern]}, local build)")
      matched=true
      break
    fi
  done
  if [[ "$matched" == false ]]; then
    MINOR_BUILDS+=("$name")
  fi
done

# Find new packages in fetch list (things not currently in the system)
NEW_PACKAGES=()
for path in "${TO_FETCH[@]}"; do
  name=$(extract_name "$path")
  # Only show packages (skip internal derivation noise like source, patch, etc.)
  if [[ "$name" =~ ^[a-z] ]] && [[ ! "$name" =~ (source|patch|hook|setup|wrapper|env|builder) ]]; then
    # Check if it's actually new (not in current system profile)
    if ! nix path-info "/run/current-system" --derivation 2>/dev/null | grep -q "$name"; then
      NEW_PACKAGES+=("$name (binary cache hit)")
    fi
  fi
done

# Print summary
echo "Rebuild impact ($HOST):"
if [[ $BUILD_COUNT -gt 0 ]]; then
  echo "  * $BUILD_COUNT derivation(s) to build"
fi
if [[ $FETCH_COUNT -gt 0 ]]; then
  echo "  * $FETCH_COUNT path(s) to fetch from cache"
fi
echo ""

if [[ ${#NOTABLE_BUILDS[@]} -gt 0 ]]; then
  echo "  Notable rebuilds:"
  for item in "${NOTABLE_BUILDS[@]}"; do
    printf "    %-30s\n" "$item"
  done
  echo ""
fi

if [[ ${#NEW_PACKAGES[@]} -gt 0 ]] && [[ ${#NEW_PACKAGES[@]} -le 10 ]]; then
  echo "  New packages:"
  for item in "${NEW_PACKAGES[@]}"; do
    printf "    %s\n" "$item"
  done
  echo ""
fi

# Estimate total time
if [[ ${#NOTABLE_BUILDS[@]} -gt 0 ]]; then
  echo "  Estimated: has expensive local builds — expect significant wait time"
elif [[ $BUILD_COUNT -gt 10 ]]; then
  echo "  Estimated: many small builds, ~5-15 min wall time"
elif [[ $BUILD_COUNT -gt 0 ]]; then
  echo "  Estimated: minor builds + cache hits, ~2-5 min wall time"
else
  echo "  Estimated: all cache hits, ~1-2 min wall time"
fi
