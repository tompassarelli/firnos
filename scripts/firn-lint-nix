#!/usr/bin/env bash
# firn-lint-nix — syntax-check generated .nix files (parallel).
# Catches codegen bugs in firn-build before they reach nix build.
set -euo pipefail

REPO="${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

# Build the file list once.
mapfile -d '' -t FILES < <(
  find "$REPO" -name "*.nix" \
    -not -path "*/.git/*" \
    -not -path "*/result/*" \
    -not -path "*/.direnv/*" \
    -not -path "*/.beagle-cache/*" \
    -not -name "hardware-configuration.nix" \
    -print0
)

# Skip when nothing to do.
if (( ${#FILES[@]} == 0 )); then
  echo "firn-lint-nix: no .nix files to lint."
  exit 0
fi

# Parallel parse via xargs. nix-instantiate --parse is purely syntactic
# (no network, no eval) so trivially parallelizable. -P = cores.
errors_file="$(mktemp)"
trap "rm -f $errors_file" EXIT

printf '%s\0' "${FILES[@]}" \
  | xargs -0 -P "$(nproc 2>/dev/null || echo 4)" -I {} \
      bash -c '
        if ! out=$(nix-instantiate --parse-only "$1" 2>&1 >/dev/null); then
          {
            echo "SYNTAX ERROR: $1"
            echo "$out" | head -5
            echo ""
          } >&2
          echo "fail" >> '"$errors_file"'
        fi
      ' _ {}

errors=$(wc -l < "$errors_file" 2>/dev/null || echo 0)

if (( errors > 0 )); then
  echo "$errors file(s) with syntax errors." >&2
  exit 1
fi

echo "firn-lint-nix: ${#FILES[@]} .nix files parse cleanly."
