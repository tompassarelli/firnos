#!/usr/bin/env racket
#lang racket/base

;; firn-validate — type-check NixOS option paths in nisp .rkt sources.
;;
;; The generic validation primitives (AST walking, value-type inference,
;; type matching, did-you-mean) live in nisp/validate. This script
;; provides the NixOS-specific orchestration:
;;
;;   - load the cached options schema from .firn-build/schema.json
;;   - lazy-expand submodules referenced by the user's config (calling
;;     `nix eval` once per batch, caching results in
;;     .firn-build/schema-submodules.json keyed by flake.lock hash)
;;   - apply NixOS-conventional fallbacks (HM-context, wildcard <name>
;;     for attrsOf submodule, "in-submodule" heuristic for paths past
;;     submodules we couldn't expand)
;;   - report errors to stderr with file:line:col precision

(require racket/file
         racket/list
         racket/string
         racket/port
         racket/path
         racket/system
         file/sha1
         json
         (only-in nisp/validate
                  path-ref-path
                  path-ref-stx
                  path-ref-val-stx
                  walk-syntax
                  extract-from-form
                  infer-value-type
                  check-type
                  find-similar-strs
                  describe-val))

(define ROOT
  (let ([start (path->complete-path (find-system-path 'orig-dir))])
    (let loop ([d (simple-form-path start)])
      (cond
        [(file-exists? (build-path d "flake.rkt")) d]
        [else
         (define-values (parent _name _isdir) (split-path d))
         (cond
           [(or (not parent) (eq? parent 'relative)) start]
           [else (loop parent)])]))))

(define SCHEMA-PATH (build-path ROOT ".firn-build" "schema.json"))
(define SUB-CACHE-PATH (build-path ROOT ".firn-build" "schema-submodules.json"))

;; Bump when the expansion logic changes — invalidates submodule cache.
(define EXTRACTOR-VERSION 1)

(unless (file-exists? SCHEMA-PATH)
  (eprintf "firn-validate: schema not found at ~a\n" SCHEMA-PATH)
  (eprintf "  run ./scripts/firn-extract-schema first.\n")
  (exit 2))

;; schema-table: path → entry hash. Mutable so we can fold in submodule
;; expansion results before the validate phase.
(define schema-table
  (let ([h (make-hash)])
    (for ([e (in-list (call-with-input-file SCHEMA-PATH read-json))])
      (hash-set! h (hash-ref e 'p) e))
    h))

;; ---------- submodule cache (flake.lock-keyed, lazy-populated) ----------

(define HOST
  (or (getenv "FIRN_HOST")
      (with-handlers ([exn:fail? (λ (_) "whiterabbit")])
        (define o (open-output-string))
        (parameterize ([current-output-port o])
          (system* (find-executable-path "hostname")))
        (define h (string-trim (get-output-string o)))
        (if (non-empty-string? h) h "whiterabbit"))))

(define (cache-key)
  (define lock (build-path ROOT "flake.lock"))
  (define lock-bytes (if (file-exists? lock) (file->bytes lock) #""))
  (string-append (sha1 (open-input-bytes lock-bytes))
                 ":v" (number->string EXTRACTOR-VERSION)
                 ":" HOST))

(define (load-sub-cache)
  (cond
    [(not (file-exists? SUB-CACHE-PATH)) (make-hash)]
    [else
     (with-handlers ([exn:fail? (λ (_) (make-hash))])
       (define data (call-with-input-file SUB-CACHE-PATH read-json))
       (cond
         [(equal? (hash-ref data 'key #f) (cache-key))
          (define h (make-hash))
          (for ([(k v) (in-hash (hash-ref data 'submodules (hash)))])
            (hash-set! h (symbol->string k) v))
          h]
         [else (make-hash)]))]))

(define (save-sub-cache cache)
  (define data
    (hash 'key (cache-key)
          'submodules
          (for/hash ([(k v) (in-hash cache)])
            (values (string->symbol k) v))))
  (call-with-output-file SUB-CACHE-PATH #:exists 'replace
    (λ (out) (write-json data out))))

(define sub-cache (load-sub-cache))

(define (merge-sub-cache!)
  (for ([(_prefix entries) (in-hash sub-cache)])
    (for ([e (in-list entries)])
      (hash-set! schema-table (hash-ref e 'p) e))))

(merge-sub-cache!)

;; ---------- NixOS-conventional fallbacks ----------

(define namespace-set
  (let ([s (make-hash)])
    (for ([p (in-hash-keys schema-table)])
      (define parts (string-split p "."))
      (let loop ([acc '()] [parts parts])
        (cond
          [(null? (cdr parts)) (void)]
          [else
           (define new-acc (cons (car parts) acc))
           (hash-set! s (string-join (reverse new-acc) ".") #t)
           (loop new-acc (cdr parts))])))
    s))

;; Types where the schema stops at the boundary — paths going deeper are
;; submodule contents that may need lazy expansion.
(define SUBMODULE-TYPES
  '("attrsOf" "submodule" "lazyAttrsOf" "listOf" "oneOf" "either"
    "functionTo" "unspecified"))

;; Top-level segments often appearing in home-manager submodule context
;; that aren't always present in the system schema. We skip unknown paths
;; whose first segment is one of these — accepting some false negatives
;; to eliminate the dominant false positives. Real typos in these
;; namespaces still surface at Nix-eval time.
(define HM-CONTEXT-ROOTS
  '("programs" "home" "xdg" "accounts" "i18n" "targets" "wayland"
    "qt" "gtk" "dconf" "fonts" "nixpkgs"))

;; NixOS module structural keywords — always valid as set targets.
(define MODULE-STRUCTURAL-KEYS
  '("config" "options" "imports" "_module" "_file"))

;; For attrsOf submodule, expansion uses a wildcard placeholder.
(define WILDCARD "<name>")

(define (expandable-submodule-prefix? entry)
  (define t (and entry (hash-ref entry 't #f)))
  (define inner-t (and entry (let ([i (hash-ref entry 'inner #f)])
                                (and i (hash-ref i 't #f)))))
  (or (equal? t "submodule")
      (and (member t '("attrsOf" "lazyAttrsOf"))
           (equal? inner-t "submodule"))))

(define (find-submodule-ancestor path)
  (let loop ([parts (string-split path ".")])
    (cond
      [(null? parts) #f]
      [(null? (cdr parts)) #f]
      [else
       (define prefix-parts (drop-right parts 1))
       (define prefix (string-join prefix-parts "."))
       (define entry (hash-ref schema-table prefix #f))
       (cond
         [(and entry (equal? (hash-ref entry 't #f) "submodule"))
          (cons prefix 'plain)]
         [(and entry (member (hash-ref entry 't #f) '("attrsOf" "lazyAttrsOf"))
               (let ([i (hash-ref entry 'inner #f)])
                 (and i (equal? (hash-ref i 't #f) "submodule"))))
          (cons prefix 'attrs)]
         [else (loop prefix-parts)])])))

(define (in-submodule? path)
  (let loop ([parts (string-split path ".")])
    (cond
      [(null? parts) #f]
      [(null? (cdr parts)) #f]
      [else
       (define prefix-parts (drop-right parts 1))
       (define prefix (string-join prefix-parts "."))
       (define entry (hash-ref schema-table prefix #f))
       (define t (and entry (hash-ref entry 't #f)))
       (cond
         [(and t (member t SUBMODULE-TYPES))
          (define cached (hash-ref sub-cache prefix #f))
          (cond
            [(and cached (not (null? cached))) #f]
            [else #t])]
         [else (loop prefix-parts)])])))

(define (has-interpolation? path)
  (regexp-match? #rx"\\$\\{" path))

(define (wildcard-lookup path)
  (define parts (string-split path "."))
  (let try-positions ([i 0])
    (cond
      [(>= i (length parts)) #f]
      [else
       (define try-parts
         (append (take parts i) (list WILDCARD) (drop parts (+ i 1))))
       (define key (string-join try-parts "."))
       (cond
         [(hash-ref schema-table key #f) => (λ (e) e)]
         [else (try-positions (+ i 1))])])))

(define (schema-type-of-with-wildcard path)
  (or (hash-ref schema-table path #f)
      (wildcard-lookup path)))

(define (validate-path path)
  (cond
    [(has-interpolation? path) 'skip]
    [(member path MODULE-STRUCTURAL-KEYS) 'structural]
    [(hash-has-key? schema-table path) 'ok]
    [(wildcard-lookup path) 'ok]
    [(hash-has-key? namespace-set path) 'namespace]
    [(in-submodule? path) 'submodule]
    [(let ([root (car (string-split path "."))])
       (member root HM-CONTEXT-ROOTS))
     'hm-context]
    [else 'unknown]))

;; ---------- did-you-mean over schema-table ----------

(define (find-similar path [max-results 3])
  (find-similar-strs path (hash-keys schema-table) max-results))

;; ---------- discovery + lazy expansion ----------

(define (count-char c s)
  (for/sum ([ch (in-string s)] #:when (char=? ch c)) 1))

(define (collect-paths-in-file f)
  (define raw (call-with-input-file f port->string))
  (define-values (lang-prefix rest)
    (let ([m (regexp-match-positions #rx"^#lang [^\n]*\n" raw)])
      (cond [m (values (substring raw 0 (cdr (car m)))
                       (substring raw (cdr (car m))))]
            [else (values "" raw)])))
  (define padded (string-append (make-string (count-char #\newline lang-prefix) #\newline)
                                rest))
  (define port (open-input-string padded))
  (port-count-lines! port)
  (define src (path->string f))
  (define paths '())
  (with-handlers ([exn:fail? (λ (_) (void))])
    (let loop ()
      (define stx (read-syntax src port))
      (unless (eof-object? stx)
        (walk-syntax stx
          (λ (s in-hm?)
            (unless in-hm?
              (for ([pr (in-list (extract-from-form s))])
                (set! paths (cons (path-ref-path pr) paths))))))
        (loop))))
  paths)

(define (build-expansion-expr prefix-pairs)
  (define pair-strs
    (map (λ (p)
           (format "{ prefix = ~s; kind = ~s; }"
                   (car p) (symbol->string (cdr p))))
         prefix-pairs))
  (define root-path (regexp-replace #rx"/+$" (path->string ROOT) ""))
  (string-append "
let
  flake = builtins.getFlake (toString " root-path ");
  opts  = flake.nixosConfigurations." HOST ".options;
  lib   = flake.inputs.nixpkgs.lib;
  pathToOpt = path:
    let segs = builtins.filter (s: s != \"\") (lib.splitString \".\" path);
    in lib.attrByPath segs null opts;
  describeType = t:
    let
      base = { t = t.name or \"?\"; };
      tryInner = if (t ? nestedTypes) && (t.nestedTypes ? elemType)
        then builtins.tryEval (describeType t.nestedTypes.elemType)
        else { success = false; value = null; };
      withInner = if tryInner.success then base // { inner = tryInner.value; } else base;
      tryEnum = if (t.name or \"\") == \"enum\" && (t ? functor) && (t.functor ? payload) && (t.functor.payload ? values)
        then builtins.tryEval t.functor.payload.values
        else { success = false; value = null; };
      withEnum = if tryEnum.success then withInner // { enum = tryEnum.value; } else withInner;
    in withEnum;
  walk = path: o:
    if (o._type or null) == \"option\"
    then [ ({ p = path; } // describeType (o.type or {})) ]
    else if builtins.isAttrs o
    then builtins.concatLists
      (builtins.attrValues
        (builtins.mapAttrs (n: v: walk (\"${path}.${n}\") v) o))
    else [];
  expandPlain = prefix:
    let o = pathToOpt prefix;
        try = builtins.tryEval (
          if o != null && (o.type.name or \"\") == \"submodule\" && (o.type ? getSubOptions)
          then walk prefix (o.type.getSubOptions [])
          else []
        );
    in if try.success then try.value else [];
  expandAttrs = prefix:
    let o = pathToOpt prefix;
        try = builtins.tryEval (
          if o != null
             && builtins.elem (o.type.name or \"\") [\"attrsOf\" \"lazyAttrsOf\"]
             && (o.type.nestedTypes.elemType.name or \"\") == \"submodule\"
             && (o.type.nestedTypes.elemType ? getSubOptions)
          then walk \"" "${prefix}." WILDCARD "\" (o.type.nestedTypes.elemType.getSubOptions [])
          else []
        );
    in if try.success then try.value else [];
  expand = pp:
    if pp.kind == \"plain\" then expandPlain pp.prefix else expandAttrs pp.prefix;
in
  builtins.listToAttrs (map (pp: { name = pp.prefix; value = expand pp; }) [
    " (string-join pair-strs "\n    ") "
  ])
"))

(define (run-nix-eval expr)
  (define out (open-output-string))
  (define err (open-output-string))
  (define ok?
    (parameterize ([current-output-port out]
                   [current-error-port err])
      (system* (find-executable-path "nix")
               "eval" "--json" "--impure" "--expr" expr)))
  (cond
    [ok?
     (with-handlers ([exn:fail? (λ (_) #f)])
       (read-json (open-input-string (get-output-string out))))]
    [else
     (eprintf "firn-validate: nix eval failed:\n~a\n" (get-output-string err))
     #f]))

(define failed-prefixes (make-hash))

(define (expand-submodule-prefixes prefix-pairs)
  (cond
    [(null? prefix-pairs) (hash)]
    [else
     (printf "firn-validate: expanding ~a submodule(s) for first-time use...\n"
             (length prefix-pairs))
     (define expr (build-expansion-expr prefix-pairs))
     (define result (run-nix-eval expr))
     (cond
       [(not result)
        (for ([p (in-list prefix-pairs)])
          (hash-set! failed-prefixes (car p) #t))
        (hash)]
       [else
        (define parsed (make-hash))
        (for ([(k v) (in-hash result)])
          (define key (symbol->string k))
          (hash-set! parsed key v)
          (cond
            [(or (null? v) (not (list? v)))
             (hash-set! sub-cache key '())
             (hash-set! failed-prefixes key #t)]
            [else
             (hash-set! sub-cache key v)
             (for ([e (in-list v)])
               (hash-set! schema-table (hash-ref e 'p) e))]))
        (save-sub-cache sub-cache)
        parsed])]))

(define (discover-and-expand! files)
  (let loop ([round 0])
    (cond
      [(>= round 5) (void)]
      [else
       (define needed
         (let ([h (make-hash)])
           (for* ([f (in-list files)]
                  [p (in-list (collect-paths-in-file f))]
                  #:unless (hash-has-key? schema-table p))
             (define anc (find-submodule-ancestor p))
             (when anc
               (define prefix (car anc))
               (define kind (cdr anc))
               (unless (or (hash-has-key? sub-cache prefix)
                           (hash-has-key? failed-prefixes prefix))
                 (hash-set! h prefix kind))))
           h))
       (cond
         [(zero? (hash-count needed)) (void)]
         [else
          (expand-submodule-prefixes
           (for/list ([(k v) (in-hash needed)]) (cons k v)))
          (loop (+ round 1))])])))

;; ---------- file processing + reporting ----------

(define total-errors 0)

(define (report-unknown-path src stx path)
  (set! total-errors (+ total-errors 1))
  (define line (or (syntax-line stx) "?"))
  (define col (or (syntax-column stx) "?"))
  (eprintf "~a:~a:~a: unknown option ~a\n" src line col path)
  (define sims (find-similar path))
  (when (not (null? sims))
    (eprintf "  did you mean: ~a?\n"
             (string-join sims ", " #:before-last " or "))))

(define (report-type-mismatch src val-stx path msg)
  (set! total-errors (+ total-errors 1))
  (define line (or (and val-stx (syntax-line val-stx)) "?"))
  (define col (or (and val-stx (syntax-column val-stx)) "?"))
  (eprintf "~a:~a:~a: type mismatch at ~a: ~a\n" src line col path msg))

(define (validate-file f)
  (define raw (call-with-input-file f port->string))
  (define-values (lang-prefix rest)
    (let ([m (regexp-match-positions #rx"^#lang [^\n]*\n" raw)])
      (cond
        [m (values (substring raw 0 (cdr (car m)))
                   (substring raw (cdr (car m))))]
        [else (values "" raw)])))
  (define padded (string-append (make-string (count-char #\newline lang-prefix) #\newline)
                                rest))
  (define port (open-input-string padded))
  (port-count-lines! port)
  (define src (path->string f))
  (with-handlers ([exn:fail:read?
                   (λ (e)
                     (eprintf "~a: parse error: ~a\n" src (exn-message e))
                     (set! total-errors (+ total-errors 1)))])
    (let loop ()
      (define stx (read-syntax src port))
      (unless (eof-object? stx)
        (walk-syntax stx
          (λ (s in-hm?)
            (unless in-hm?
              (for ([pr (in-list (extract-from-form s))])
                (define p (path-ref-path pr))
                (define stx-loc (path-ref-stx pr))
                (define val-stx (path-ref-val-stx pr))
                (case (validate-path p)
                  [(unknown) (report-unknown-path src stx-loc p)]
                  [(ok)
                   (when val-stx
                     (define entry (schema-type-of-with-wildcard p))
                     (when entry
                       (define val-type (infer-value-type val-stx))
                       (define result (check-type entry val-type))
                       (when (and (pair? result) (eq? (car result) 'mismatch))
                         (report-type-mismatch src val-stx p (cadr result)))))]
                  [else (void)])))))
        (loop)))))

;; ---------- main ----------

(define files
  (let ([args (vector->list (current-command-line-arguments))])
    (cond
      [(null? args)
       (sort
        (for/list ([f (in-directory ROOT)]
                   #:when (let ([ps (path->string f)])
                            (and (regexp-match? #rx"\\.rkt$" ps)
                                 (not (regexp-match? #rx"/scripts/" ps))
                                 (not (regexp-match? #rx"/tests/" ps))
                                 (not (regexp-match? #rx"/\\.firn-build/" ps))
                                 (not (regexp-match? #rx"/\\.direnv/" ps))
                                 (not (regexp-match? #rx"/\\.git/" ps))
                                 (not (regexp-match? #rx"/result" ps))
                                 (with-handlers ([exn:fail? (λ (_) #f)])
                                   (regexp-match?
                                    #rx"^#lang nisp"
                                    (call-with-input-file f
                                      (λ (p) (read-line p))))))))
          f)
        string<? #:key path->string)]
      [else (map string->path args)])))

(printf "firn-validate: discovering submodule prefixes...\n")
(discover-and-expand! files)

(printf "firn-validate: checking ~a file(s) against ~a option paths...\n"
        (length files) (hash-count schema-table))

(for ([f (in-list files)])
  (validate-file f))

(if (zero? total-errors)
    (printf "firn-validate: clean — no unknown options.\n")
    (eprintf "\n~a error(s).\n" total-errors))

(exit (if (zero? total-errors) 0 1))
