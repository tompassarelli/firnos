#!/usr/bin/env bash
# firn-validate — validates .bnix source files against the NixOS option schema.
#
# Uses beagle-validate for source-level validation (option paths, types,
# duplicates, cross-file conflicts).
#
# Also runs firn-lint-nix to syntax-check generated .nix files.

set -euo pipefail

REPO="${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
BEAGLE_PATH="${BEAGLE_PATH:-$(cd "$REPO/.." && pwd)/beagle}"
BEAGLE_VALIDATE="$BEAGLE_PATH/bin/beagle-validate"

# Syntax-check generated .nix files (firn-lint-nix prints its own status)
if ! "$REPO/scripts/firn-lint-nix"; then
  echo "firn-validate: generated .nix has syntax errors (firn-build codegen bug?)" >&2
  exit 1
fi

if [[ ! -x "$BEAGLE_VALIDATE" ]]; then
  echo "firn-validate: beagle-validate not found at $BEAGLE_VALIDATE" >&2
  echo "  set BEAGLE_PATH=/path/to/beagle" >&2
  exit 2
fi

cd "$REPO"

# If the caller passed explicit files, validate exactly those. Otherwise
# auto-discover .bnix files excluding tests/fixtures (which contain
# intentionally-broken fixtures invoked individually by validator-test.rkt).
if (( $# > 0 )); then
  exec "$BEAGLE_VALIDATE" "$@"
else
  mapfile -t FILES < <(find . -type f -name '*.bnix' \
    -not -path './tests/fixtures/*' \
    -not -path './result/*' \
    -not -path './.direnv/*' | sort)
  exec "$BEAGLE_VALIDATE" "${FILES[@]}"
fi
