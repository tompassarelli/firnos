#!/usr/bin/env bash
# firn-validate — thin wrapper around `nisp validate`.
#
# Configures the validator for this repo's NixOS-specific conventions:
#   target:     nixosConfigurations.<hostname>.options
#   cache-dir:  <repo-root>/.nisp-cache
#   hm-roots:   programs,home,xdg,accounts,i18n,targets,wayland,qt,gtk,dconf,fonts,nixpkgs
#
# Pass-through args go to `nisp validate` (e.g. specific files to check).

set -euo pipefail

REPO="${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
NISP_PATH="${NISP_PATH:-$(cd "$REPO/.." && pwd)/nisp}"

if [[ ! -f "$NISP_PATH/bin/nisp" ]]; then
  echo "firn-validate: nisp dispatcher not found at $NISP_PATH/bin/nisp" >&2
  echo "  clone nisp: git clone https://github.com/tompassarelli/nisp \"$NISP_PATH\"" >&2
  echo "  or set NISP_PATH=/path/to/nisp" >&2
  exit 2
fi

# Auto-extract package cache if missing or stale (flake.lock newer)
PKG_CACHE="$REPO/.nisp-cache/packages.json"
if [[ ! -f "$PKG_CACHE" ]] || [[ "$REPO/flake.lock" -nt "$PKG_CACHE" ]]; then
  echo "firn-validate: refreshing package cache..."
  "$REPO/scripts/firn-extract-packages" || true
fi

# Syntax-check generated .nix files
if ! "$REPO/scripts/firn-lint-nix"; then
  echo "firn-validate: generated .nix has syntax errors (firn-build codegen bug?)" >&2
  exit 1
fi

exec racket "$NISP_PATH/bin/nisp" validate \
  --flake "$REPO" \
  --cache-dir "$REPO/.nisp-cache" \
  --hm-roots "programs,home,xdg,accounts,i18n,targets,wayland,qt,gtk,dconf,fonts,nixpkgs" \
  "$@"
