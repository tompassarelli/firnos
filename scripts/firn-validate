#!/usr/bin/env racket
#lang racket/base

;; firn-validate — type-check NixOS option paths in nisp .rkt sources.
;;
;; Three phases:
;;   Discover: walk every (set 'PATH ...) / (enable 'PATH ...). For any
;;             path not in the base schema, find its closest ancestor
;;             with t=submodule. Those ancestors are submodule prefixes
;;             we need expanded into the schema.
;;   Expand:   for prefixes not yet in the on-disk submodule cache, run
;;             one batched `nix eval` that calls getSubOptions [] on each
;;             and walks the inner option tree. Cache result keyed by
;;             flake.lock hash.
;;   Validate: Phase 1 (path exists?) + Phase 2 (value type matches?)
;;             with file:line:col precision and did-you-mean suggestions.
;;
;; Usage:
;;   ./scripts/firn-validate                  # check every .rkt
;;   ./scripts/firn-validate <files...>       # check specific files
;;
;; Base schema is regenerated by ./scripts/firn-extract-schema.
;; Submodule cache lives at .firn-build/schema-submodules.json (auto-managed).

(require racket/file
         racket/list
         racket/string
         racket/port
         racket/path
         racket/system
         file/sha1
         json)

(define ROOT
  (let ([start (path->complete-path (find-system-path 'orig-dir))])
    (let loop ([d (simple-form-path start)])
      (cond
        [(file-exists? (build-path d "flake.rkt")) d]
        [else
         (define-values (parent _name _isdir) (split-path d))
         (cond
           [(or (not parent) (eq? parent 'relative)) start]
           [else (loop parent)])]))))

(define SCHEMA-PATH (build-path ROOT ".firn-build" "schema.json"))
(define SUB-CACHE-PATH (build-path ROOT ".firn-build" "schema-submodules.json"))

;; Bump when the expansion logic changes — invalidates submodule cache.
(define EXTRACTOR-VERSION 1)

(unless (file-exists? SCHEMA-PATH)
  (eprintf "firn-validate: schema not found at ~a\n" SCHEMA-PATH)
  (eprintf "  run ./scripts/firn-extract-schema first.\n")
  (exit 2))

;; schema-table: path → hash with keys 't (string), 'inner (hash, optional),
;; 'enum (list of strings, optional). The hash is the original JSON entry
;; minus 'p, so lookup is O(1). Mutable so we can fold in submodule
;; expansion results before the validate phase.
(define schema-table
  (let ([h (make-hash)])
    (for ([e (in-list (call-with-input-file SCHEMA-PATH read-json))])
      (hash-set! h (hash-ref e 'p) e))
    h))

;; ---------- submodule cache (flake.lock-keyed, lazy-populated) ----------

(define HOST
  (or (getenv "FIRN_HOST")
      (with-handlers ([exn:fail? (λ (_) "whiterabbit")])
        (define o (open-output-string))
        (parameterize ([current-output-port o])
          (system* (find-executable-path "hostname")))
        (define h (string-trim (get-output-string o)))
        (if (non-empty-string? h) h "whiterabbit"))))

(define (cache-key)
  (define lock (build-path ROOT "flake.lock"))
  (define lock-bytes (if (file-exists? lock) (file->bytes lock) #""))
  (string-append (sha1 (open-input-bytes lock-bytes))
                 ":v" (number->string EXTRACTOR-VERSION)
                 ":" HOST))

(define (load-sub-cache)
  ;; Returns a hash of prefix → list of {p, t, ...}. Empty if cache missing
  ;; or stale (key mismatch).
  (cond
    [(not (file-exists? SUB-CACHE-PATH)) (make-hash)]
    [else
     (with-handlers ([exn:fail? (λ (_) (make-hash))])
       (define data (call-with-input-file SUB-CACHE-PATH read-json))
       (cond
         [(equal? (hash-ref data 'key #f) (cache-key))
          (define h (make-hash))
          (for ([(k v) (in-hash (hash-ref data 'submodules (hash)))])
            (hash-set! h (symbol->string k) v))
          h]
         [else (make-hash)]))]))

(define (save-sub-cache cache)
  (define data
    (hash 'key (cache-key)
          'submodules
          (for/hash ([(k v) (in-hash cache)])
            (values (string->symbol k) v))))
  (call-with-output-file SUB-CACHE-PATH #:exists 'replace
    (λ (out) (write-json data out))))

(define sub-cache (load-sub-cache))

(define (merge-sub-cache!)
  ;; Fold every cached entry into schema-table.
  (for ([(_prefix entries) (in-hash sub-cache)])
    (for ([e (in-list entries)])
      (hash-set! schema-table (hash-ref e 'p) e))))

(merge-sub-cache!)

(define (schema-type-of path) (hash-ref schema-table path #f))

;; Build a set of "namespace prefixes" — every dotted-path prefix of any
;; schema entry. So if `services.openssh.enable` is in the schema, then
;; `services`, `services.openssh` are valid namespaces.
(define namespace-set
  (let ([s (make-hash)])
    (for ([p (in-hash-keys schema-table)])
      (define parts (string-split p "."))
      (let loop ([acc '()] [parts parts])
        (cond
          [(null? (cdr parts)) (void)]   ; don't add the leaf itself
          [else
           (define new-acc (cons (car parts) acc))
           (hash-set! s (string-join (reverse new-acc) ".") #t)
           (loop new-acc (cdr parts))])))
    s))

;; Types where the schema stops at the boundary — paths going deeper are
;; submodule contents that may need lazy expansion.
(define SUBMODULE-TYPES
  '("attrsOf" "submodule" "lazyAttrsOf" "listOf" "oneOf" "either"
    "functionTo" "unspecified"))

;; Types whose path-extension is *expandable*: either the option itself is a
;; submodule, or it's an attrsOf/lazyAttrsOf whose inner type is a submodule.
(define (expandable-submodule-prefix? entry)
  (define t (and entry (hash-ref entry 't #f)))
  (define inner-t (and entry (let ([i (hash-ref entry 'inner #f)])
                                (and i (hash-ref i 't #f)))))
  (or (equal? t "submodule")
      (and (member t '("attrsOf" "lazyAttrsOf"))
           (equal? inner-t "submodule"))))

;; For attrsOf submodule, expansion uses a wildcard placeholder for the
;; dynamic key segment. So users.users → expand → users.users.<name>.X
(define WILDCARD "<name>")

;; Given a path like users.users.tom.shell, find the closest ancestor in
;; the schema that's an expandable submodule prefix. Returns either:
;;   #f               — no such ancestor
;;   (cons P 'plain)  — P is a `submodule` option; expand getSubOptions
;;                      and emit entries P.X
;;   (cons P 'attrs)  — P is `attrsOf submodule`; expand getSubOptions
;;                      on its inner type, emit entries P.<name>.X
(define (find-submodule-ancestor path)
  (let loop ([parts (string-split path ".")])
    (cond
      [(null? parts) #f]
      [(null? (cdr parts)) #f]
      [else
       (define prefix-parts (drop-right parts 1))
       (define prefix (string-join prefix-parts "."))
       (define entry (hash-ref schema-table prefix #f))
       (cond
         [(and entry (equal? (hash-ref entry 't #f) "submodule"))
          (cons prefix 'plain)]
         [(and entry (member (hash-ref entry 't #f) '("attrsOf" "lazyAttrsOf"))
               (let ([i (hash-ref entry 'inner #f)])
                 (and i (equal? (hash-ref i 't #f) "submodule"))))
          (cons prefix 'attrs)]
         [else (loop prefix-parts)])])))

;; Top-level segments that frequently appear in home-manager / submodule
;; context and aren't always present in the system schema. When validating,
;; we skip unknown paths whose first segment is one of these — accepting
;; some false negatives to eliminate the dominant false positives. Real
;; typos in these namespaces will still be caught at Nix-eval time.
(define HM-CONTEXT-ROOTS
  '("programs" "home" "xdg" "accounts" "i18n" "targets" "wayland"
    "qt" "gtk" "dconf" "fonts" "nixpkgs"))

;; NixOS module structural keywords — always valid as set targets in any
;; module sub-file or inline-module-builder context.
(define MODULE-STRUCTURAL-KEYS
  '("config" "options" "imports" "_module" "_file"))

(define (in-submodule? path)
  ;; Walk ancestors. If the closest submodule-typed ancestor was successfully
  ;; expanded (its prefix is in sub-cache with non-empty entries), DON'T
  ;; accept this path as a submodule fallback — its absence from the
  ;; expanded schema means it's a real typo. If the ancestor failed to
  ;; expand or wasn't expanded, accept the heuristic.
  (let loop ([parts (string-split path ".")])
    (cond
      [(null? parts) #f]
      [(null? (cdr parts)) #f]
      [else
       (define prefix-parts (drop-right parts 1))
       (define prefix (string-join prefix-parts "."))
       (define entry (hash-ref schema-table prefix #f))
       (define t (and entry (hash-ref entry 't #f)))
       (cond
         [(and t (member t SUBMODULE-TYPES))
          (define cached (hash-ref sub-cache prefix #f))
          (cond
            ;; Successfully expanded with content → trust the expansion;
            ;; path is unknown.
            [(and cached (not (null? cached))) #f]
            ;; Not expanded or expansion came back empty → keep heuristic.
            [else #t])]
         [else (loop prefix-parts)])])))

(define (has-interpolation? path)
  (regexp-match? #rx"\\$\\{" path))

;; Wildcard match: try substituting each segment with WILDCARD ("<name>")
;; and see if any substituted variant is in schema-table. So path
;; users.users.tom.shell matches a cache entry users.users.<name>.shell.
;; Returns the matched entry or #f. Tries one wildcard at a time, segment
;; by segment from left to right (matches the "users.users.<name>" pattern).
(define (wildcard-lookup path)
  (define parts (string-split path "."))
  (let try-positions ([i 0])
    (cond
      [(>= i (length parts)) #f]
      [else
       (define try-parts
         (append (take parts i) (list WILDCARD) (drop parts (+ i 1))))
       (define key (string-join try-parts "."))
       (cond
         [(hash-ref schema-table key #f) => (λ (e) e)]
         [else (try-positions (+ i 1))])])))

(define (schema-type-of-with-wildcard path)
  (or (hash-ref schema-table path #f)
      (wildcard-lookup path)))

(define (validate-path path)
  (cond
    [(has-interpolation? path) 'skip]
    [(member path MODULE-STRUCTURAL-KEYS) 'structural]
    [(hash-has-key? schema-table path) 'ok]
    [(wildcard-lookup path) 'ok]
    [(hash-has-key? namespace-set path) 'namespace]
    [(in-submodule? path) 'submodule]
    [(let ([root (car (string-split path "."))])
       (member root HM-CONTEXT-ROOTS))
     'hm-context]
    [else 'unknown]))

;; ---------- did-you-mean (Levenshtein) ----------

(define (levenshtein a b)
  (define m (string-length a))
  (define n (string-length b))
  (cond
    [(zero? m) n]
    [(zero? n) m]
    [else
     (define prev (make-vector (+ n 1)))
     (define curr (make-vector (+ n 1)))
     (for ([j (in-range (+ n 1))]) (vector-set! prev j j))
     (for ([i (in-range 1 (+ m 1))])
       (vector-set! curr 0 i)
       (for ([j (in-range 1 (+ n 1))])
         (define cost (if (char=? (string-ref a (- i 1))
                                  (string-ref b (- j 1)))
                          0 1))
         (vector-set! curr j
           (min (+ (vector-ref prev j) 1)
                (+ (vector-ref curr (- j 1)) 1)
                (+ (vector-ref prev (- j 1)) cost))))
       (define tmp prev) (set! prev curr) (set! curr tmp))
     (vector-ref prev n)]))

(define (find-similar path [max-results 3])
  (define max-edits
    (max 2 (min 5 (quotient (string-length path) 6))))
  (define cands
    (for/list ([p (in-hash-keys schema-table)]
               #:when (<= (levenshtein path p) max-edits))
      (cons (levenshtein path p) p)))
  (define sorted (sort cands < #:key car))
  (map cdr (if (> (length sorted) max-results)
               (take sorted max-results)
               sorted)))

(define (find-similar-strs target candidates [max-results 3])
  (define max-edits
    (max 2 (min 4 (quotient (string-length target) 3))))
  (define cands
    (for/list ([s (in-list candidates)]
               #:when (<= (levenshtein target s) max-edits))
      (cons (levenshtein target s) s)))
  (define sorted (sort cands < #:key car))
  (map cdr (if (> (length sorted) max-results)
               (take sorted max-results)
               sorted)))

;; ---------- value type inference ----------
;;
;; Walk a value-side syntax object and try to classify what kind of Nix
;; value it produces. Returns one of:
;;
;;   '(bool)               #t / #f
;;   '(str)                string literal, (s …), (ms …)
;;   '(int)                integer literal
;;   '(float)              floating-point literal
;;   '(null)               null literal (the symbol `null`)
;;   '(path)               (p …) form
;;   '(packages)           (with-pkgs …) — list of package
;;   `(list ,types)        (lst …) — types is list of inferred element types
;;   '(attrset)            (att …)
;;   `(str-lit ,value)     string literal — value preserved for enum check
;;   '(unknown)            anything else (let-bound names, calls, mk*, etc.)

(define (infer-value-type stx)
  (define dat (and (syntax? stx) (syntax->datum stx)))
  (cond
    [(boolean? dat) '(bool)]
    [(exact-integer? dat) '(int)]
    [(real? dat) '(float)]
    [(string? dat) (list 'str-lit dat)]
    [(eq? dat 'null) '(null)]
    [(pair? dat)
     (define lst (syntax->list stx))
     (cond
       [(or (not lst) (null? lst)) '(unknown)]
       [else
        (define head-stx (car lst))
        (define head (and (identifier? head-stx) (syntax->datum head-stx)))
        (define args (cdr lst))
        (case head
          [(s ms) '(str)]
          [(p) '(path)]
          [(with-pkgs) '(packages)]
          [(lst) (list 'list (map infer-value-type args))]
          [(att)
           ;; (att (k v) ...) — capture the value-types of each entry so
           ;; we can recurse into them when matching against attrsOf X.
           (define val-types
             (filter-map
              (λ (entry)
                (define elst (and (syntax? entry) (syntax->list entry)))
                (and elst (= (length elst) 2)
                     (infer-value-type (cadr elst))))
              args))
           (list 'attrset val-types)]
          ;; mkdefault, mkforce, mkif — unwrap
          [(mkdefault mkforce)
           (if (and (pair? args) (not (null? args)))
               (infer-value-type (car args))
               '(unknown))]
          [(mkif)
           (if (and (pair? args) (not (null? (cdr args))))
               (infer-value-type (cadr args))
               '(unknown))]
          [else '(unknown)])])]
    [else '(unknown)]))

(define (attrset-val-types val-type)
  ;; Helper: extract inner val-types from a `(attrset ((tag ...) ...))`
  ;; tagged value or '(attrset) legacy form.
  (cond
    [(and (pair? val-type) (eq? (car val-type) 'attrset)
          (pair? (cdr val-type)))
     (cadr val-type)]
    [else '()]))

;; ---------- type matching ----------
;;
;; Given a schema-entry (hash with 't, 'inner, 'enum) and an inferred
;; value-type, return one of:
;;   'ok                 — types are compatible (or check skipped)
;;   'unknown            — couldn't determine (don't report)
;;   `(mismatch ,msg)    — definite mismatch; msg is a short description
;;
;; The matcher is intentionally conservative — only flag when CERTAIN.

(define STR-TYPES
  '("str" "string" "singleLineStr" "passwdEntry" "separatedString"
    "lines" "commas" "envVar"))

(define INT-TYPES
  '("int" "ints.unsigned" "ints.positive" "ints.between"
    "unsignedInt8" "unsignedInt16" "unsignedInt32" "unsignedInt64"
    "signedInt8" "signedInt16" "signedInt32" "signedInt64"
    "port" "u8" "u16" "u32" "u64" "s8" "s16" "s32" "s64"))

(define PERMISSIVE-TYPES
  ;; Types where we can't statically check meaningfully.
  '("submodule" "anything" "unspecified" "raw"
    "either" "oneOf" "coercedTo" "addCheck" "functionTo" "package"
    "deferredModule" "optionType" "loaOf" "uniq" "attrs" "freeformType"))

(define (str-type? t)
  (or (member t STR-TYPES)
      (and (string? t) (regexp-match? #rx"^strMatching" t))))

(define (int-type? t)
  (or (member t INT-TYPES)
      (and (string? t) (regexp-match? #rx"^ints\\." t))))

(define (permissive-type? t)
  (or (member t PERMISSIVE-TYPES)
      (and (string? t) (regexp-match? #rx"^enum$" t)) ; handled separately
      ))

(define (path-type? t) (member t '("path" "pathInStore")))
(define (bool-type? t) (equal? t "bool"))
(define (float-type? t) (or (equal? t "float") (equal? t "number")))

(define (check-type expected-entry val-type)
  (define t (hash-ref expected-entry 't "?"))
  (define val-tag (car val-type))
  (cond
    ;; Permissive — skip
    [(member t PERMISSIVE-TYPES) 'ok]
    [(equal? t "?") 'ok]

    ;; Unknown value — can't check
    [(eq? val-tag 'unknown) 'unknown]

    ;; bool
    [(bool-type? t)
     (case val-tag
       [(bool) 'ok]
       [else `(mismatch ,(format "expected bool, got ~a" (describe-val val-type)))])]

    ;; str
    [(str-type? t)
     (case val-tag
       [(str str-lit) 'ok]
       [else `(mismatch ,(format "expected ~a, got ~a" t (describe-val val-type)))])]

    ;; int
    [(int-type? t)
     (case val-tag
       [(int) 'ok]
       [else `(mismatch ,(format "expected ~a, got ~a" t (describe-val val-type)))])]

    ;; float
    [(float-type? t)
     (case val-tag
       [(float int) 'ok]
       [else `(mismatch ,(format "expected ~a, got ~a" t (describe-val val-type)))])]

    ;; path
    [(path-type? t)
     (case val-tag
       [(path str str-lit) 'ok]
       [else `(mismatch ,(format "expected path, got ~a" (describe-val val-type)))])]

    ;; nullOr X
    [(equal? t "nullOr")
     (cond
       [(eq? val-tag 'null) 'ok]
       [(hash-ref expected-entry 'inner #f)
        => (λ (inner) (check-type inner val-type))]
       [else 'ok])]

    ;; attrsOf X / lazyAttrsOf X — value must be an attrset, and each
    ;; inner value must match X. Catches the "nested attrs where leaf
    ;; scalar expected" bug class (e.g. boot.kernel.sysctl with `(att (vm
    ;; (att (swappiness 180))))` — the inner `(att …)` where a scalar was
    ;; expected fires here).
    [(member t '("attrsOf" "lazyAttrsOf"))
     (case val-tag
       [(attrset)
        (define inner (hash-ref expected-entry 'inner #f))
        (cond
          [(not inner) 'ok]
          [(member (hash-ref inner 't "?") PERMISSIVE-TYPES) 'ok]
          [else
           (define inner-vals (attrset-val-types val-type))
           (define mismatches
             (filter (λ (r) (and (pair? r) (eq? (car r) 'mismatch)))
                     (map (λ (v) (check-type inner v)) inner-vals)))
           (if (null? mismatches) 'ok (car mismatches))])]
       [else `(mismatch ,(format "expected attrset, got ~a" (describe-val val-type)))])]

    ;; listOf X
    [(equal? t "listOf")
     (case val-tag
       [(packages)
        ;; Only valid if inner is package or unspecified
        (define inner (hash-ref expected-entry 'inner #f))
        (define inner-t (and inner (hash-ref inner 't "?")))
        (if (or (not inner-t) (equal? inner-t "package") (member inner-t PERMISSIVE-TYPES))
            'ok
            `(mismatch ,(format "expected listOf ~a, got list of packages" inner-t)))]
       [(list)
        (define inner (hash-ref expected-entry 'inner #f))
        (cond
          [(not inner) 'ok]
          [else
           (define elems (cadr val-type))
           (define mismatches
             (filter (λ (r) (and (pair? r) (eq? (car r) 'mismatch)))
                     (map (λ (e) (check-type inner e)) elems)))
           (if (null? mismatches)
               'ok
               (car mismatches))])]
       [else `(mismatch ,(format "expected list, got ~a" (describe-val val-type)))])]

    ;; enum
    [(equal? t "enum")
     (define enum-vals (hash-ref expected-entry 'enum #f))
     (cond
       [(not enum-vals) 'ok]
       [(eq? val-tag 'str-lit)
        (define v (cadr val-type))
        (if (member v enum-vals)
            'ok
            (let ([sims (find-similar-strs v enum-vals)])
              `(mismatch
                ,(format "~s not in enum {~a}~a"
                         v
                         (string-join (map (λ (s) (format "~s" s)) enum-vals) ", ")
                         (if (null? sims)
                             ""
                             (format " — did you mean ~a?"
                                     (string-join (map (λ (s) (format "~s" s)) sims)
                                                  " or ")))))))]
       [(eq? val-tag 'str) 'unknown]   ; (s …) interpolation — skip
       [else `(mismatch ,(format "expected enum string, got ~a" (describe-val val-type)))])]

    [else 'ok]))

(define (describe-val val-type)
  (case (car val-type)
    [(bool) "bool"]
    [(int) "int"]
    [(float) "float"]
    [(str str-lit) "string"]
    [(null) "null"]
    [(path) "path"]
    [(packages) "list of packages"]
    [(list) "list"]
    [(attrset) "attrset"]
    [else "unknown"]))

;; ---------- syntax walking ----------

(struct path-ref (path stx val-stx) #:transparent)

(define (extract-quoted-sym stx)
  (define lst (syntax->list stx))
  (and lst
       (= (length lst) 2)
       (let ([head (and (identifier? (car lst))
                        (syntax->datum (car lst)))])
         (and (eq? head 'quote)
              (let ([inner (syntax->datum (cadr lst))])
                (and (symbol? inner) (symbol->string inner)))))))

(define (extract-from-form stx)
  (define lst (syntax->list stx))
  (cond
    [(or (not lst) (null? lst)) '()]
    [else
     (define head (and (identifier? (car lst))
                       (syntax->datum (car lst))))
     (define rest (cdr lst))
     (cond
       [(and (eq? head 'set) (not (null? rest)))
        (define maybe-path (extract-quoted-sym (car rest)))
        (define val-stx (and (not (null? (cdr rest))) (cadr rest)))
        (if maybe-path
            (list (path-ref maybe-path (car rest) val-stx))
            '())]
       [(eq? head 'enable)
        (filter-map
         (λ (arg)
           (define p (extract-quoted-sym arg))
           (and p (path-ref (string-append p ".enable") arg #f)))
         rest)]
       [else '()])]))

;; Walk syntax tree with context. The visitor receives (stx in-hm?) where
;; in-hm? is true when we're inside a home-of/home-of-bare/hm/hm-bare body.
(define (walk-syntax stx visit [in-hm? #f])
  (visit stx in-hm?)
  (define lst (syntax->list stx))
  (when lst
    (define head (and (pair? lst) (identifier? (car lst))
                      (syntax->datum (car lst))))
    (define child-hm?
      (or in-hm? (member head '(home-of home-of-bare hm hm-bare hm-module))))
    (for-each (λ (s) (walk-syntax s visit child-hm?)) lst)))

;; ---------- file processing ----------

(define total-errors 0)

(define (report-unknown-path src stx path)
  (set! total-errors (+ total-errors 1))
  (define line (or (syntax-line stx) "?"))
  (define col (or (syntax-column stx) "?"))
  (eprintf "~a:~a:~a: unknown option ~a\n" src line col path)
  (define sims (find-similar path))
  (when (not (null? sims))
    (eprintf "  did you mean: ~a?\n"
             (string-join sims ", " #:before-last " or "))))

(define (report-type-mismatch src val-stx path msg)
  (set! total-errors (+ total-errors 1))
  (define line (or (and val-stx (syntax-line val-stx)) "?"))
  (define col (or (and val-stx (syntax-column val-stx)) "?"))
  (eprintf "~a:~a:~a: type mismatch at ~a: ~a\n" src line col path msg))

(define (validate-file f)
  (define raw (call-with-input-file f port->string))
  (define-values (lang-prefix rest)
    (let ([m (regexp-match-positions #rx"^#lang [^\n]*\n" raw)])
      (cond
        [m (values (substring raw 0 (cdr (car m)))
                   (substring raw (cdr (car m))))]
        [else (values "" raw)])))
  ;; Replace lang line with same number of newlines so source positions match
  (define lang-newlines (count-char #\newline lang-prefix))
  (define padded (string-append (make-string lang-newlines #\newline) rest))
  (define port (open-input-string padded))
  (port-count-lines! port)
  (define src (path->string f))
  (with-handlers ([exn:fail:read?
                   (λ (e)
                     (eprintf "~a: parse error: ~a\n" src (exn-message e))
                     (set! total-errors (+ total-errors 1)))])
    (let loop ()
      (define stx (read-syntax src port))
      (unless (eof-object? stx)
        (walk-syntax stx
          (λ (s in-hm?)
            (unless in-hm?
              (for ([pr (in-list (extract-from-form s))])
                (define p (path-ref-path pr))
                (define stx-loc (path-ref-stx pr))
                (define val-stx (path-ref-val-stx pr))
                (case (validate-path p)
                  [(unknown) (report-unknown-path src stx-loc p)]
                  [(ok)
                   ;; Phase 2: type-check the value.
                   (when val-stx
                     (define entry (schema-type-of-with-wildcard p))
                     (when entry
                       (define val-type (infer-value-type val-stx))
                       (define result (check-type entry val-type))
                       (when (and (pair? result) (eq? (car result) 'mismatch))
                         (report-type-mismatch src val-stx p (cadr result)))))]
                  [else (void)])))))
        (loop)))))

(define (count-char c s)
  (for/sum ([ch (in-string s)] #:when (char=? ch c)) 1))

;; ---------- discovery: collect option paths used in .rkt sources ----------

(define (collect-paths-in-file f)
  ;; Read syntax of f, walk, return list of dotted-path strings.
  (define raw (call-with-input-file f port->string))
  (define-values (lang-prefix rest)
    (let ([m (regexp-match-positions #rx"^#lang [^\n]*\n" raw)])
      (cond [m (values (substring raw 0 (cdr (car m)))
                       (substring raw (cdr (car m))))]
            [else (values "" raw)])))
  (define padded (string-append (make-string (count-char #\newline lang-prefix) #\newline)
                                rest))
  (define port (open-input-string padded))
  (port-count-lines! port)
  (define src (path->string f))
  (define paths '())
  (with-handlers ([exn:fail? (λ (_) (void))])
    (let loop ()
      (define stx (read-syntax src port))
      (unless (eof-object? stx)
        (walk-syntax stx
          (λ (s in-hm?)
            (unless in-hm?
              (for ([pr (in-list (extract-from-form s))])
                (set! paths (cons (path-ref-path pr) paths))))))
        (loop))))
  paths)

;; ---------- expansion via batched nix eval ----------
;;
;; Given a list of (prefix . kind) pairs, generates a Nix expression that
;; expands each prefix's submodule via getSubOptions, walks the inner option
;; tree, and returns an attrset { prefix → [ {p, t, ...}, ... ] }.

(define (build-expansion-expr prefix-pairs)
  ;; Render the list of prefixes into a Nix [["prefix" "kind"] ...] list.
  (define pair-strs
    (map (λ (p)
           (define prefix (car p))
           (define kind (cdr p))
           (format "{ prefix = ~s; kind = ~s; }"
                   prefix (symbol->string kind)))
         prefix-pairs))
  ;; Strip trailing slash — Nix rejects paths ending in /.
  (define root-path
    (regexp-replace #rx"/+$" (path->string ROOT) ""))
  (string-append "
let
  flake = builtins.getFlake (toString " root-path ");
  opts  = flake.nixosConfigurations." HOST ".options;
  lib   = flake.inputs.nixpkgs.lib;
  pathToOpt = path:
    let segs = builtins.filter (s: s != \"\") (lib.splitString \".\" path);
    in lib.attrByPath segs null opts;
  describeType = t:
    let
      base = { t = t.name or \"?\"; };
      tryInner = if (t ? nestedTypes) && (t.nestedTypes ? elemType)
        then builtins.tryEval (describeType t.nestedTypes.elemType)
        else { success = false; value = null; };
      withInner = if tryInner.success then base // { inner = tryInner.value; } else base;
      tryEnum = if (t.name or \"\") == \"enum\" && (t ? functor) && (t.functor ? payload) && (t.functor.payload ? values)
        then builtins.tryEval t.functor.payload.values
        else { success = false; value = null; };
      withEnum = if tryEnum.success then withInner // { enum = tryEnum.value; } else withInner;
    in withEnum;
  walk = path: o:
    if (o._type or null) == \"option\"
    then [ ({ p = path; } // describeType (o.type or {})) ]
    else if builtins.isAttrs o
    then builtins.concatLists
      (builtins.attrValues
        (builtins.mapAttrs (n: v: walk (\"${path}.${n}\") v) o))
    else [];
  expandPlain = prefix:
    let o = pathToOpt prefix;
        try = builtins.tryEval (
          if o != null && (o.type.name or \"\") == \"submodule\" && (o.type ? getSubOptions)
          then walk prefix (o.type.getSubOptions [])
          else []
        );
    in if try.success then try.value else [];
  expandAttrs = prefix:
    let o = pathToOpt prefix;
        try = builtins.tryEval (
          if o != null
             && builtins.elem (o.type.name or \"\") [\"attrsOf\" \"lazyAttrsOf\"]
             && (o.type.nestedTypes.elemType.name or \"\") == \"submodule\"
             && (o.type.nestedTypes.elemType ? getSubOptions)
          then walk \"" "${prefix}." WILDCARD "\" (o.type.nestedTypes.elemType.getSubOptions [])
          else []
        );
    in if try.success then try.value else [];
  expand = pp:
    if pp.kind == \"plain\" then expandPlain pp.prefix else expandAttrs pp.prefix;
in
  builtins.listToAttrs (map (pp: { name = pp.prefix; value = expand pp; }) [
    " (string-join pair-strs "\n    ") "
  ])
"))

(define (run-nix-eval expr)
  ;; Run nix eval --json --impure --expr <expr>; return parsed JSON or #f.
  (define out (open-output-string))
  (define err (open-output-string))
  (define ok?
    (parameterize ([current-output-port out]
                   [current-error-port err])
      (system* (find-executable-path "nix")
               "eval" "--json" "--impure" "--expr" expr)))
  (cond
    [ok?
     (with-handlers ([exn:fail? (λ (_) #f)])
       (read-json (open-input-string (get-output-string out))))]
    [else
     (eprintf "firn-validate: nix eval failed:\n~a\n" (get-output-string err))
     #f]))

;; Tracks prefixes we've attempted but couldn't expand — marker prevents
;; the discover-and-expand loop from retrying them every iteration.
(define failed-prefixes (make-hash))

(define (expand-submodule-prefixes prefix-pairs)
  ;; Returns a hash of prefix → entries. Updates sub-cache + persists.
  (cond
    [(null? prefix-pairs) (hash)]
    [else
     (printf "firn-validate: expanding ~a submodule(s) for first-time use...\n"
             (length prefix-pairs))
     (define expr (build-expansion-expr prefix-pairs))
     (define result (run-nix-eval expr))
     (cond
       [(not result)
        ;; Mark all attempted prefixes as failed so we don't retry.
        (for ([p (in-list prefix-pairs)])
          (hash-set! failed-prefixes (car p) #t))
        (hash)]
       [else
        (define parsed (make-hash))
        (for ([(k v) (in-hash result)])
          (define key (symbol->string k))
          (hash-set! parsed key v)
          (cond
            [(or (null? v) (not (list? v)))
             ;; Empty expansion — submodule had no extractable options.
             ;; Cache the empty result so we don't keep retrying.
             (hash-set! sub-cache key '())
             (hash-set! failed-prefixes key #t)]
            [else
             (hash-set! sub-cache key v)
             (for ([e (in-list v)])
               (hash-set! schema-table (hash-ref e 'p) e))]))
        (save-sub-cache sub-cache)
        parsed])]))

(define (discover-and-expand! files)
  ;; Iterate: collect used paths → find unexpanded submodule ancestors →
  ;; batch-expand → fold into schema → repeat. Bounded to avoid infinite
  ;; loops on pathological cases.
  (let loop ([round 0])
    (cond
      [(>= round 5) (void)]
      [else
       (define needed
         (let ([h (make-hash)])
           (for* ([f (in-list files)]
                  [p (in-list (collect-paths-in-file f))]
                  #:unless (hash-has-key? schema-table p))
             (define anc (find-submodule-ancestor p))
             (when anc
               (define prefix (car anc))
               (define kind (cdr anc))
               (unless (or (hash-has-key? sub-cache prefix)
                           (hash-has-key? failed-prefixes prefix))
                 (hash-set! h prefix kind))))
           h))
       (cond
         [(zero? (hash-count needed)) (void)]
         [else
          (expand-submodule-prefixes
           (for/list ([(k v) (in-hash needed)]) (cons k v)))
          (loop (+ round 1))])])))

;; ---------- main ----------

(define files
  (let ([args (vector->list (current-command-line-arguments))])
    (cond
      [(null? args)
       (sort
        (for/list ([f (in-directory ROOT)]
                   #:when (let ([ps (path->string f)])
                            (and (regexp-match? #rx"\\.rkt$" ps)
                                 (not (regexp-match? #rx"/nisp/" ps))
                                 (not (regexp-match? #rx"/scripts/" ps))
                                 (not (regexp-match? #rx"/\\.firn-build/" ps))
                                 (not (regexp-match? #rx"/\\.direnv/" ps))
                                 (not (regexp-match? #rx"/\\.git/" ps))
                                 (not (regexp-match? #rx"/result" ps))
                                 ;; Only #lang nisp files
                                 (with-handlers ([exn:fail? (λ (_) #f)])
                                   (regexp-match?
                                    #rx"^#lang nisp"
                                    (call-with-input-file f
                                      (λ (p) (read-line p))))))))
          f)
        string<? #:key path->string)]
      [else (map string->path args)])))

(printf "firn-validate: discovering submodule prefixes...\n")
(discover-and-expand! files)

(printf "firn-validate: checking ~a file(s) against ~a option paths...\n"
        (length files) (hash-count schema-table))

(for ([f (in-list files)])
  (validate-file f))

(if (zero? total-errors)
    (printf "firn-validate: clean — no unknown options.\n")
    (eprintf "\n~a error(s).\n" total-errors))

(exit (if (zero? total-errors) 0 1))
