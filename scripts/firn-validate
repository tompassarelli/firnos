#!/usr/bin/env racket
#lang racket/base

;; firn-validate — type-check NixOS option paths in nisp .rkt sources.
;;
;; Two passes:
;;   Phase 1: every (set 'PATH ...) and (enable 'PATH ...) — check the path
;;            exists in the schema. Did-you-mean suggestions on miss.
;;   Phase 2: for known paths, statically check that the value's shape
;;            matches the schema's expected type (bool / str / int /
;;            listOf X / nullOr X / enum {...}).
;;
;; Both passes report file:line:col precision, point to the offending stx.
;;
;; Usage:
;;   ./scripts/firn-validate                  # check every .rkt
;;   ./scripts/firn-validate <files...>       # check specific files
;;
;; Schema is regenerated by ./scripts/firn-extract-schema.

(require racket/file
         racket/list
         racket/string
         racket/port
         racket/path
         json)

(define ROOT
  (let ([p (find-system-path 'orig-dir)])
    (let loop ([d p])
      (cond [(file-exists? (build-path d "flake.rkt")) d]
            [(equal? d (or (path-only d) d)) p]
            [else (loop (path-only d))]))))

(define SCHEMA-PATH (build-path ROOT ".firn-build" "schema.json"))

(unless (file-exists? SCHEMA-PATH)
  (eprintf "firn-validate: schema not found at ~a\n" SCHEMA-PATH)
  (eprintf "  run ./scripts/firn-extract-schema first.\n")
  (exit 2))

;; schema-table: path → hash with keys 't (string), 'inner (hash, optional),
;; 'enum (list of strings, optional). The hash is the original JSON entry
;; minus 'p, so lookup is O(1).
(define schema-table
  (let ([h (make-hash)])
    (for ([e (in-list (call-with-input-file SCHEMA-PATH read-json))])
      (hash-set! h (hash-ref e 'p) e))
    h))

(define (schema-type-of path) (hash-ref schema-table path #f))

;; Build a set of "namespace prefixes" — every dotted-path prefix of any
;; schema entry. So if `services.openssh.enable` is in the schema, then
;; `services`, `services.openssh` are valid namespaces.
(define namespace-set
  (let ([s (make-hash)])
    (for ([p (in-hash-keys schema-table)])
      (define parts (string-split p "."))
      (let loop ([acc '()] [parts parts])
        (cond
          [(null? (cdr parts)) (void)]   ; don't add the leaf itself
          [else
           (define new-acc (cons (car parts) acc))
           (hash-set! s (string-join (reverse new-acc) ".") #t)
           (loop new-acc (cdr parts))])))
    s))

;; Types where the schema stops at the boundary — paths going deeper are
;; submodule contents we didn't extract.
(define SUBMODULE-TYPES
  '("attrsOf" "submodule" "lazyAttrsOf" "listOf" "oneOf" "either"
    "functionTo" "unspecified"))

;; Top-level segments that frequently appear in home-manager / submodule
;; context and aren't always present in the system schema. When validating,
;; we skip unknown paths whose first segment is one of these — accepting
;; some false negatives to eliminate the dominant false positives. Real
;; typos in these namespaces will still be caught at Nix-eval time.
(define HM-CONTEXT-ROOTS
  '("programs" "home" "xdg" "accounts" "i18n" "targets" "wayland"
    "qt" "gtk" "dconf" "fonts" "nixpkgs"))

;; NixOS module structural keywords — always valid as set targets in any
;; module sub-file or inline-module-builder context.
(define MODULE-STRUCTURAL-KEYS
  '("config" "options" "imports" "_module" "_file"))

(define (in-submodule? path)
  (let loop ([parts (string-split path ".")])
    (cond
      [(null? parts) #f]
      [(null? (cdr parts)) #f]
      [else
       (define prefix-parts (drop-right parts 1))
       (define prefix (string-join prefix-parts "."))
       (define entry (hash-ref schema-table prefix #f))
       (define t (and entry (hash-ref entry 't #f)))
       (cond
         [(and t (member t SUBMODULE-TYPES)) #t]
         [else (loop prefix-parts)])])))

(define (has-interpolation? path)
  (regexp-match? #rx"\\$\\{" path))

(define (validate-path path)
  (cond
    [(has-interpolation? path) 'skip]
    [(member path MODULE-STRUCTURAL-KEYS) 'structural]
    [(hash-has-key? schema-table path) 'ok]
    [(hash-has-key? namespace-set path) 'namespace]
    [(in-submodule? path) 'submodule]
    [(let ([root (car (string-split path "."))])
       (member root HM-CONTEXT-ROOTS))
     'hm-context]
    [else 'unknown]))

;; ---------- did-you-mean (Levenshtein) ----------

(define (levenshtein a b)
  (define m (string-length a))
  (define n (string-length b))
  (cond
    [(zero? m) n]
    [(zero? n) m]
    [else
     (define prev (make-vector (+ n 1)))
     (define curr (make-vector (+ n 1)))
     (for ([j (in-range (+ n 1))]) (vector-set! prev j j))
     (for ([i (in-range 1 (+ m 1))])
       (vector-set! curr 0 i)
       (for ([j (in-range 1 (+ n 1))])
         (define cost (if (char=? (string-ref a (- i 1))
                                  (string-ref b (- j 1)))
                          0 1))
         (vector-set! curr j
           (min (+ (vector-ref prev j) 1)
                (+ (vector-ref curr (- j 1)) 1)
                (+ (vector-ref prev (- j 1)) cost))))
       (define tmp prev) (set! prev curr) (set! curr tmp))
     (vector-ref prev n)]))

(define (find-similar path [max-results 3])
  (define max-edits
    (max 2 (min 5 (quotient (string-length path) 6))))
  (define cands
    (for/list ([p (in-hash-keys schema-table)]
               #:when (<= (levenshtein path p) max-edits))
      (cons (levenshtein path p) p)))
  (define sorted (sort cands < #:key car))
  (map cdr (if (> (length sorted) max-results)
               (take sorted max-results)
               sorted)))

(define (find-similar-strs target candidates [max-results 3])
  (define max-edits
    (max 2 (min 4 (quotient (string-length target) 3))))
  (define cands
    (for/list ([s (in-list candidates)]
               #:when (<= (levenshtein target s) max-edits))
      (cons (levenshtein target s) s)))
  (define sorted (sort cands < #:key car))
  (map cdr (if (> (length sorted) max-results)
               (take sorted max-results)
               sorted)))

;; ---------- value type inference ----------
;;
;; Walk a value-side syntax object and try to classify what kind of Nix
;; value it produces. Returns one of:
;;
;;   '(bool)               #t / #f
;;   '(str)                string literal, (s …), (ms …)
;;   '(int)                integer literal
;;   '(float)              floating-point literal
;;   '(null)               null literal (the symbol `null`)
;;   '(path)               (p …) form
;;   '(packages)           (with-pkgs …) — list of package
;;   `(list ,types)        (lst …) — types is list of inferred element types
;;   '(attrset)            (att …)
;;   `(str-lit ,value)     string literal — value preserved for enum check
;;   '(unknown)            anything else (let-bound names, calls, mk*, etc.)

(define (infer-value-type stx)
  (define dat (and (syntax? stx) (syntax->datum stx)))
  (cond
    [(boolean? dat) '(bool)]
    [(exact-integer? dat) '(int)]
    [(real? dat) '(float)]
    [(string? dat) (list 'str-lit dat)]
    [(eq? dat 'null) '(null)]
    [(pair? dat)
     (define lst (syntax->list stx))
     (cond
       [(or (not lst) (null? lst)) '(unknown)]
       [else
        (define head-stx (car lst))
        (define head (and (identifier? head-stx) (syntax->datum head-stx)))
        (define args (cdr lst))
        (case head
          [(s ms) '(str)]
          [(p) '(path)]
          [(with-pkgs) '(packages)]
          [(lst) (list 'list (map infer-value-type args))]
          [(att) '(attrset)]
          ;; mkdefault, mkforce, mkif — unwrap
          [(mkdefault mkforce)
           (if (and (pair? args) (not (null? args)))
               (infer-value-type (car args))
               '(unknown))]
          [(mkif)
           (if (and (pair? args) (not (null? (cdr args))))
               (infer-value-type (cadr args))
               '(unknown))]
          [else '(unknown)])])]
    [else '(unknown)]))

;; ---------- type matching ----------
;;
;; Given a schema-entry (hash with 't, 'inner, 'enum) and an inferred
;; value-type, return one of:
;;   'ok                 — types are compatible (or check skipped)
;;   'unknown            — couldn't determine (don't report)
;;   `(mismatch ,msg)    — definite mismatch; msg is a short description
;;
;; The matcher is intentionally conservative — only flag when CERTAIN.

(define STR-TYPES
  '("str" "string" "singleLineStr" "passwdEntry" "separatedString"
    "lines" "commas" "envVar"))

(define INT-TYPES
  '("int" "ints.unsigned" "ints.positive" "ints.between"
    "unsignedInt8" "unsignedInt16" "unsignedInt32" "unsignedInt64"
    "signedInt8" "signedInt16" "signedInt32" "signedInt64"
    "port" "u8" "u16" "u32" "u64" "s8" "s16" "s32" "s64"))

(define PERMISSIVE-TYPES
  ;; Types where we can't statically check meaningfully.
  '("submodule" "attrsOf" "lazyAttrsOf" "anything" "unspecified" "raw"
    "either" "oneOf" "coercedTo" "addCheck" "functionTo" "package"
    "deferredModule" "optionType" "loaOf" "uniq" "attrs" "freeformType"))

(define (str-type? t)
  (or (member t STR-TYPES)
      (and (string? t) (regexp-match? #rx"^strMatching" t))))

(define (int-type? t)
  (or (member t INT-TYPES)
      (and (string? t) (regexp-match? #rx"^ints\\." t))))

(define (permissive-type? t)
  (or (member t PERMISSIVE-TYPES)
      (and (string? t) (regexp-match? #rx"^enum$" t)) ; handled separately
      ))

(define (path-type? t) (member t '("path" "pathInStore")))
(define (bool-type? t) (equal? t "bool"))
(define (float-type? t) (or (equal? t "float") (equal? t "number")))

(define (check-type expected-entry val-type)
  (define t (hash-ref expected-entry 't "?"))
  (define val-tag (car val-type))
  (cond
    ;; Permissive — skip
    [(member t PERMISSIVE-TYPES) 'ok]
    [(equal? t "?") 'ok]

    ;; Unknown value — can't check
    [(eq? val-tag 'unknown) 'unknown]

    ;; bool
    [(bool-type? t)
     (case val-tag
       [(bool) 'ok]
       [else `(mismatch ,(format "expected bool, got ~a" (describe-val val-type)))])]

    ;; str
    [(str-type? t)
     (case val-tag
       [(str str-lit) 'ok]
       [else `(mismatch ,(format "expected ~a, got ~a" t (describe-val val-type)))])]

    ;; int
    [(int-type? t)
     (case val-tag
       [(int) 'ok]
       [else `(mismatch ,(format "expected ~a, got ~a" t (describe-val val-type)))])]

    ;; float
    [(float-type? t)
     (case val-tag
       [(float int) 'ok]
       [else `(mismatch ,(format "expected ~a, got ~a" t (describe-val val-type)))])]

    ;; path
    [(path-type? t)
     (case val-tag
       [(path str str-lit) 'ok]
       [else `(mismatch ,(format "expected path, got ~a" (describe-val val-type)))])]

    ;; nullOr X
    [(equal? t "nullOr")
     (cond
       [(eq? val-tag 'null) 'ok]
       [(hash-ref expected-entry 'inner #f)
        => (λ (inner) (check-type inner val-type))]
       [else 'ok])]

    ;; listOf X
    [(equal? t "listOf")
     (case val-tag
       [(packages)
        ;; Only valid if inner is package or unspecified
        (define inner (hash-ref expected-entry 'inner #f))
        (define inner-t (and inner (hash-ref inner 't "?")))
        (if (or (not inner-t) (equal? inner-t "package") (member inner-t PERMISSIVE-TYPES))
            'ok
            `(mismatch ,(format "expected listOf ~a, got list of packages" inner-t)))]
       [(list)
        (define inner (hash-ref expected-entry 'inner #f))
        (cond
          [(not inner) 'ok]
          [else
           (define elems (cadr val-type))
           (define mismatches
             (filter (λ (r) (and (pair? r) (eq? (car r) 'mismatch)))
                     (map (λ (e) (check-type inner e)) elems)))
           (if (null? mismatches)
               'ok
               (car mismatches))])]
       [else `(mismatch ,(format "expected list, got ~a" (describe-val val-type)))])]

    ;; enum
    [(equal? t "enum")
     (define enum-vals (hash-ref expected-entry 'enum #f))
     (cond
       [(not enum-vals) 'ok]
       [(eq? val-tag 'str-lit)
        (define v (cadr val-type))
        (if (member v enum-vals)
            'ok
            (let ([sims (find-similar-strs v enum-vals)])
              `(mismatch
                ,(format "~s not in enum {~a}~a"
                         v
                         (string-join (map (λ (s) (format "~s" s)) enum-vals) ", ")
                         (if (null? sims)
                             ""
                             (format " — did you mean ~a?"
                                     (string-join (map (λ (s) (format "~s" s)) sims)
                                                  " or ")))))))]
       [(eq? val-tag 'str) 'unknown]   ; (s …) interpolation — skip
       [else `(mismatch ,(format "expected enum string, got ~a" (describe-val val-type)))])]

    [else 'ok]))

(define (describe-val val-type)
  (case (car val-type)
    [(bool) "bool"]
    [(int) "int"]
    [(float) "float"]
    [(str str-lit) "string"]
    [(null) "null"]
    [(path) "path"]
    [(packages) "list of packages"]
    [(list) "list"]
    [(attrset) "attrset"]
    [else "unknown"]))

;; ---------- syntax walking ----------

(struct path-ref (path stx val-stx) #:transparent)

(define (extract-quoted-sym stx)
  (define lst (syntax->list stx))
  (and lst
       (= (length lst) 2)
       (let ([head (and (identifier? (car lst))
                        (syntax->datum (car lst)))])
         (and (eq? head 'quote)
              (let ([inner (syntax->datum (cadr lst))])
                (and (symbol? inner) (symbol->string inner)))))))

(define (extract-from-form stx)
  (define lst (syntax->list stx))
  (cond
    [(or (not lst) (null? lst)) '()]
    [else
     (define head (and (identifier? (car lst))
                       (syntax->datum (car lst))))
     (define rest (cdr lst))
     (cond
       [(and (eq? head 'set) (not (null? rest)))
        (define maybe-path (extract-quoted-sym (car rest)))
        (define val-stx (and (not (null? (cdr rest))) (cadr rest)))
        (if maybe-path
            (list (path-ref maybe-path (car rest) val-stx))
            '())]
       [(eq? head 'enable)
        (filter-map
         (λ (arg)
           (define p (extract-quoted-sym arg))
           (and p (path-ref (string-append p ".enable") arg #f)))
         rest)]
       [else '()])]))

;; Walk syntax tree with context. The visitor receives (stx in-hm?) where
;; in-hm? is true when we're inside a home-of/home-of-bare/hm/hm-bare body.
(define (walk-syntax stx visit [in-hm? #f])
  (visit stx in-hm?)
  (define lst (syntax->list stx))
  (when lst
    (define head (and (pair? lst) (identifier? (car lst))
                      (syntax->datum (car lst))))
    (define child-hm?
      (or in-hm? (member head '(home-of home-of-bare hm hm-bare hm-module))))
    (for-each (λ (s) (walk-syntax s visit child-hm?)) lst)))

;; ---------- file processing ----------

(define total-errors 0)

(define (report-unknown-path src stx path)
  (set! total-errors (+ total-errors 1))
  (define line (or (syntax-line stx) "?"))
  (define col (or (syntax-column stx) "?"))
  (eprintf "~a:~a:~a: unknown option ~a\n" src line col path)
  (define sims (find-similar path))
  (when (not (null? sims))
    (eprintf "  did you mean: ~a?\n"
             (string-join sims ", " #:before-last " or "))))

(define (report-type-mismatch src val-stx path msg)
  (set! total-errors (+ total-errors 1))
  (define line (or (and val-stx (syntax-line val-stx)) "?"))
  (define col (or (and val-stx (syntax-column val-stx)) "?"))
  (eprintf "~a:~a:~a: type mismatch at ~a: ~a\n" src line col path msg))

(define (validate-file f)
  (define raw (call-with-input-file f port->string))
  (define-values (lang-prefix rest)
    (let ([m (regexp-match-positions #rx"^#lang [^\n]*\n" raw)])
      (cond
        [m (values (substring raw 0 (cdr (car m)))
                   (substring raw (cdr (car m))))]
        [else (values "" raw)])))
  ;; Replace lang line with same number of newlines so source positions match
  (define lang-newlines (count-char #\newline lang-prefix))
  (define padded (string-append (make-string lang-newlines #\newline) rest))
  (define port (open-input-string padded))
  (port-count-lines! port)
  (define src (path->string f))
  (with-handlers ([exn:fail:read?
                   (λ (e)
                     (eprintf "~a: parse error: ~a\n" src (exn-message e))
                     (set! total-errors (+ total-errors 1)))])
    (let loop ()
      (define stx (read-syntax src port))
      (unless (eof-object? stx)
        (walk-syntax stx
          (λ (s in-hm?)
            (unless in-hm?
              (for ([pr (in-list (extract-from-form s))])
                (define p (path-ref-path pr))
                (define stx-loc (path-ref-stx pr))
                (define val-stx (path-ref-val-stx pr))
                (case (validate-path p)
                  [(unknown) (report-unknown-path src stx-loc p)]
                  [(ok)
                   ;; Phase 2: type-check the value.
                   (when val-stx
                     (define entry (schema-type-of p))
                     (when entry
                       (define val-type (infer-value-type val-stx))
                       (define result (check-type entry val-type))
                       (when (and (pair? result) (eq? (car result) 'mismatch))
                         (report-type-mismatch src val-stx p (cadr result)))))]
                  [else (void)])))))
        (loop)))))

(define (count-char c s)
  (for/sum ([ch (in-string s)] #:when (char=? ch c)) 1))

;; ---------- main ----------

(define files
  (let ([args (vector->list (current-command-line-arguments))])
    (cond
      [(null? args)
       (sort
        (for/list ([f (in-directory ROOT)]
                   #:when (let ([ps (path->string f)])
                            (and (regexp-match? #rx"\\.rkt$" ps)
                                 (not (regexp-match? #rx"/nisp/" ps))
                                 (not (regexp-match? #rx"/scripts/" ps))
                                 (not (regexp-match? #rx"/\\.firn-build/" ps))
                                 (not (regexp-match? #rx"/\\.direnv/" ps))
                                 (not (regexp-match? #rx"/\\.git/" ps))
                                 (not (regexp-match? #rx"/result" ps))
                                 ;; Only #lang nisp files
                                 (with-handlers ([exn:fail? (λ (_) #f)])
                                   (regexp-match?
                                    #rx"^#lang nisp"
                                    (call-with-input-file f
                                      (λ (p) (read-line p))))))))
          f)
        string<? #:key path->string)]
      [else (map string->path args)])))

(printf "firn-validate: checking ~a file(s) against ~a option paths...\n"
        (length files) (hash-count schema-table))

(for ([f (in-list files)])
  (validate-file f))

(if (zero? total-errors)
    (printf "firn-validate: clean — no unknown options.\n")
    (eprintf "\n~a error(s).\n" total-errors))

(exit (if (zero? total-errors) 0 1))
