#!/usr/bin/env racket
#lang racket/base

;; firn-validate — type-check NixOS option paths in nisp .rkt sources.
;;
;; Loads the cached options schema (.firn-build/schema.json), walks every
;; .rkt file looking for (set 'PATH ...) and (enable 'PATH ...) calls, and
;; reports any path that doesn't exist in the schema — with file:line:col
;; precision and did-you-mean suggestions.
;;
;; Usage:
;;   ./scripts/firn-validate                  # check every .rkt
;;   ./scripts/firn-validate <files...>       # check specific files
;;
;; Schema is regenerated by ./scripts/firn-extract-schema.

(require racket/file
         racket/list
         racket/string
         racket/port
         racket/path
         json)

(define ROOT
  (let ([p (find-system-path 'orig-dir)])
    (let loop ([d p])
      (cond [(file-exists? (build-path d "flake.rkt")) d]
            [(equal? d (or (path-only d) d)) p]
            [else (loop (path-only d))]))))

(define SCHEMA-PATH (build-path ROOT ".firn-build" "schema.json"))

(unless (file-exists? SCHEMA-PATH)
  (eprintf "firn-validate: schema not found at ~a\n" SCHEMA-PATH)
  (eprintf "  run ./scripts/firn-extract-schema first.\n")
  (exit 2))

(define schema-table
  (let ([h (make-hash)])
    (for ([e (in-list (call-with-input-file SCHEMA-PATH read-json))])
      (hash-set! h (hash-ref e 'p) (hash-ref e 't)))
    h))

;; Build a set of "namespace prefixes" — every dotted-path prefix of any
;; schema entry. So if `services.openssh.enable` is in the schema, then
;; `services`, `services.openssh` are valid namespaces.
(define namespace-set
  (let ([s (make-hash)])
    (for ([p (in-hash-keys schema-table)])
      (define parts (string-split p "."))
      (let loop ([acc '()] [parts parts])
        (cond
          [(null? (cdr parts)) (void)]   ; don't add the leaf itself
          [else
           (define new-acc (cons (car parts) acc))
           (hash-set! s (string-join (reverse new-acc) ".") #t)
           (loop new-acc (cdr parts))])))
    s))

;; Types where the schema stops at the boundary — paths going deeper are
;; submodule contents we didn't extract.
(define SUBMODULE-TYPES
  '("attrsOf" "submodule" "lazyAttrsOf" "listOf" "oneOf" "either"
    "functionTo" "unspecified"))

;; Top-level segments that frequently appear in home-manager / submodule
;; context and aren't always present in the system schema. When validating,
;; we skip unknown paths whose first segment is one of these — accepting
;; some false negatives to eliminate the dominant false positives. Real
;; typos in these namespaces will still be caught at Nix-eval time.
(define HM-CONTEXT-ROOTS
  '("programs" "home" "xdg" "accounts" "i18n" "targets" "wayland"
    "qt" "gtk" "dconf" "fonts" "nixpkgs"))

;; NixOS module structural keywords — always valid as set targets in any
;; module sub-file or inline-module-builder context.
(define MODULE-STRUCTURAL-KEYS
  '("config" "options" "imports" "_module" "_file"))

(define (in-submodule? path)
  (let loop ([parts (string-split path ".")])
    (cond
      [(null? parts) #f]
      [(null? (cdr parts)) #f]
      [else
       (define prefix-parts (drop-right parts 1))
       (define prefix (string-join prefix-parts "."))
       (define t (hash-ref schema-table prefix #f))
       (cond
         [(and t (member t SUBMODULE-TYPES)) #t]
         [else (loop prefix-parts)])])))

(define (has-interpolation? path)
  (regexp-match? #rx"\\$\\{" path))

(define (validate-path path)
  (cond
    [(has-interpolation? path) 'skip]
    [(member path MODULE-STRUCTURAL-KEYS) 'structural]
    [(hash-has-key? schema-table path) 'ok]
    [(hash-has-key? namespace-set path) 'namespace]
    [(in-submodule? path) 'submodule]
    [(let ([root (car (string-split path "."))])
       (member root HM-CONTEXT-ROOTS))
     'hm-context]
    [else 'unknown]))

;; ---------- did-you-mean (Levenshtein) ----------

(define (levenshtein a b)
  (define m (string-length a))
  (define n (string-length b))
  (cond
    [(zero? m) n]
    [(zero? n) m]
    [else
     (define prev (make-vector (+ n 1)))
     (define curr (make-vector (+ n 1)))
     (for ([j (in-range (+ n 1))]) (vector-set! prev j j))
     (for ([i (in-range 1 (+ m 1))])
       (vector-set! curr 0 i)
       (for ([j (in-range 1 (+ n 1))])
         (define cost (if (char=? (string-ref a (- i 1))
                                  (string-ref b (- j 1)))
                          0 1))
         (vector-set! curr j
           (min (+ (vector-ref prev j) 1)
                (+ (vector-ref curr (- j 1)) 1)
                (+ (vector-ref prev (- j 1)) cost))))
       (define tmp prev) (set! prev curr) (set! curr tmp))
     (vector-ref prev n)]))

(define (find-similar path [max-results 3])
  (define max-edits
    (max 2 (min 5 (quotient (string-length path) 6))))
  (define cands
    (for/list ([p (in-hash-keys schema-table)]
               #:when (<= (levenshtein path p) max-edits))
      (cons (levenshtein path p) p)))
  (define sorted (sort cands < #:key car))
  (map cdr (if (> (length sorted) max-results)
               (take sorted max-results)
               sorted)))

;; ---------- syntax walking ----------

(struct path-ref (path stx) #:transparent)

(define (extract-quoted-sym stx)
  (define lst (syntax->list stx))
  (and lst
       (= (length lst) 2)
       (let ([head (and (identifier? (car lst))
                        (syntax->datum (car lst)))])
         (and (eq? head 'quote)
              (let ([inner (syntax->datum (cadr lst))])
                (and (symbol? inner) (symbol->string inner)))))))

(define (extract-from-form stx)
  (define lst (syntax->list stx))
  (cond
    [(or (not lst) (null? lst)) '()]
    [else
     (define head (and (identifier? (car lst))
                       (syntax->datum (car lst))))
     (define rest (cdr lst))
     (cond
       [(and (eq? head 'set) (not (null? rest)))
        (define maybe-path (extract-quoted-sym (car rest)))
        (if maybe-path
            (list (path-ref maybe-path (car rest)))
            '())]
       [(eq? head 'enable)
        (filter-map
         (λ (arg)
           (define p (extract-quoted-sym arg))
           (and p (path-ref (string-append p ".enable") arg)))
         rest)]
       [else '()])]))

;; Walk syntax tree with context. The visitor receives (stx in-hm?) where
;; in-hm? is true when we're inside a home-of/home-of-bare/hm/hm-bare body.
(define (walk-syntax stx visit [in-hm? #f])
  (visit stx in-hm?)
  (define lst (syntax->list stx))
  (when lst
    (define head (and (pair? lst) (identifier? (car lst))
                      (syntax->datum (car lst))))
    (define child-hm?
      (or in-hm? (member head '(home-of home-of-bare hm hm-bare hm-module))))
    (for-each (λ (s) (walk-syntax s visit child-hm?)) lst)))

;; ---------- file processing ----------

(define total-errors 0)

(define (report-error src stx path)
  (set! total-errors (+ total-errors 1))
  (define line (or (syntax-line stx) "?"))
  (define col (or (syntax-column stx) "?"))
  (eprintf "~a:~a:~a: unknown option ~a\n" src line col path)
  (define sims (find-similar path))
  (when (not (null? sims))
    (eprintf "  did you mean: ~a?\n"
             (string-join sims ", " #:before-last " or "))))

(define (validate-file f)
  (define raw (call-with-input-file f port->string))
  (define-values (lang-prefix rest)
    (let ([m (regexp-match-positions #rx"^#lang [^\n]*\n" raw)])
      (cond
        [m (values (substring raw 0 (cdr (car m)))
                   (substring raw (cdr (car m))))]
        [else (values "" raw)])))
  ;; Replace lang line with same number of newlines so source positions match
  (define lang-newlines (count-char #\newline lang-prefix))
  (define padded (string-append (make-string lang-newlines #\newline) rest))
  (define port (open-input-string padded))
  (port-count-lines! port)
  (define src (path->string f))
  (with-handlers ([exn:fail:read?
                   (λ (e)
                     (eprintf "~a: parse error: ~a\n" src (exn-message e))
                     (set! total-errors (+ total-errors 1)))])
    (let loop ()
      (define stx (read-syntax src port))
      (unless (eof-object? stx)
        (walk-syntax stx
          (λ (s in-hm?)
            (unless in-hm?
              (for ([pr (in-list (extract-from-form s))])
                (define p (path-ref-path pr))
                (define stx-loc (path-ref-stx pr))
                (case (validate-path p)
                  [(unknown) (report-error src stx-loc p)]
                  [else (void)])))))
        (loop)))))

(define (count-char c s)
  (for/sum ([ch (in-string s)] #:when (char=? ch c)) 1))

;; ---------- main ----------

(define files
  (let ([args (vector->list (current-command-line-arguments))])
    (cond
      [(null? args)
       (sort
        (for/list ([f (in-directory ROOT)]
                   #:when (let ([ps (path->string f)])
                            (and (regexp-match? #rx"\\.rkt$" ps)
                                 (not (regexp-match? #rx"/nisp/" ps))
                                 (not (regexp-match? #rx"/scripts/" ps))
                                 (not (regexp-match? #rx"/\\.firn-build/" ps))
                                 (not (regexp-match? #rx"/\\.direnv/" ps))
                                 (not (regexp-match? #rx"/\\.git/" ps))
                                 (not (regexp-match? #rx"/result" ps))
                                 ;; Only #lang nisp files
                                 (with-handlers ([exn:fail? (λ (_) #f)])
                                   (regexp-match?
                                    #rx"^#lang nisp"
                                    (call-with-input-file f
                                      (λ (p) (read-line p))))))))
          f)
        string<? #:key path->string)]
      [else (map string->path args)])))

(printf "firn-validate: checking ~a file(s) against ~a option paths...\n"
        (length files) (hash-count schema-table))

(for ([f (in-list files)])
  (validate-file f))

(if (zero? total-errors)
    (printf "firn-validate: clean — no unknown options.\n")
    (eprintf "\n~a error(s).\n" total-errors))

(exit (if (zero? total-errors) 0 1))
