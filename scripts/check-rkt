#!/usr/bin/env bash
# check-rkt — fast paren/syntax check for nisp .rkt sources.
#
# Strips the `#lang nisp` line and reads the rest as plain s-exprs via Racket's
# `read`. Catches: unbalanced parens, mismatched bracket types, unterminated
# strings/comments — with file:line:col precision. Does NOT load the nisp
# language (so it's fast: ~50ms/file vs ~300ms for `racket <file>`).
# Does NOT catch: unbound identifiers, macro errors, semantic bugs.
#
# Usage:
#   ./scripts/check-rkt                       # check every .rkt under repo
#   ./scripts/check-rkt path/to/file.rkt ...  # check specific files

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if [ "$#" -eq 0 ]; then
  mapfile -t files < <(find . -name '*.rkt' -not -path './nisp/*' -not -path './.firn-build/*' -not -path './result*' | sort)
else
  files=("$@")
fi

errors=0
for f in "${files[@]}"; do
  # Strip leading #lang line (if any), feed rest to racket as stdin.
  if ! sed '1{/^#lang/d}' "$f" | racket -e '
    (define src (string->symbol "stdin"))
    (port-count-lines! (current-input-port))
    (with-handlers ([exn:fail:read?
                     (λ (e)
                       (eprintf "~a: ~a~n" (vector-ref (current-command-line-arguments) 0)
                                          (exn-message e))
                       (exit 1))])
      (let loop ()
        (define x (read-syntax src (current-input-port)))
        (unless (eof-object? x) (loop))))' "$f" 2>&1; then
    errors=$((errors + 1))
  fi
done

if [ "$errors" -gt 0 ]; then
  echo "check-rkt: $errors file(s) failed paren/syntax check." >&2
  exit 1
fi

echo "check-rkt: ${#files[@]} file(s) passed."
