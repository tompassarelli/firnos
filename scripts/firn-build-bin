#!/usr/bin/env bash
# firn-build-bin — compile scripts/firn.rkt to a small fast binary.
#
# Uses `raco demod` (whole-program optimizer + dead-code elimination) to
# produce a ~1.3 MB bytecode file that loads in ~80 ms. Installs:
#   ~/.local/bin/firn         — wrapper shell script (calls racket on the .zo)
#   ~/.local/share/firn/firn.zo — compiled bytecode
#
# Why not `raco exe`? It works (single 6 MB binary, ~110 ms cold) but produces
# a noticeably larger artifact and is slower than demod.
#
# Why not `raco distribute`? It's for shipping to machines *without* Racket;
# bundles the whole runtime as a 50 MB directory. We have Racket installed.

set -euo pipefail

cd "${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
BEAGLE_PATH="${BEAGLE_PATH:-$(cd .. && pwd)/beagle}"

BIN_DIR="${BIN_DIR:-$HOME/.local/bin}"
SHARE_DIR="${SHARE_DIR:-$HOME/.local/share/firn}"
mkdir -p "$BIN_DIR" "$SHARE_DIR"

ZO="$SHARE_DIR/firn.zo"
WRAPPER="$BIN_DIR/firn"

# firn.rkt requires beagle libraries. If beagle has stale .zo files
# (typical after a nixpkgs racket bump), `raco demod` below will fail
# loading them. Detect-and-refresh up front: compare current racket
# version against a marker; if changed, nuke beagle's compiled/ dirs
# and run raco setup so demod can read fresh bytecode.
RACKET_VERSION="$(racket --version 2>/dev/null | grep -oP 'v\K[0-9.]+')"
MARKER="$SHARE_DIR/racket-version"
STORED_VERSION="$(cat "$MARKER" 2>/dev/null || echo "")"

if [ "$RACKET_VERSION" != "$STORED_VERSION" ] && [ -d "$BEAGLE_PATH" ]; then
  echo "firn-build-bin: racket version changed (was: ${STORED_VERSION:-unknown}, now: $RACKET_VERSION) → recompiling beagle libs"
  find "$BEAGLE_PATH" -name compiled -type d -exec rm -rf {} + 2>/dev/null || true
  raco setup --pkgs beagle-lib beagle-test beagle-doc beagle 2>&1 \
    | grep -E "error|warning|done|--- summary" \
    | head -10 \
    || true
  echo "$RACKET_VERSION" > "$MARKER"
fi

echo "firn-build-bin: compiling scripts/firn.rkt → $ZO"
raco demod -o "$ZO" scripts/firn.rkt

cat > "$WRAPPER" <<EOF
#!/usr/bin/env bash
# firn — wrapper for the compiled bytecode at $ZO.
#
# Strategy: detect Racket version change at startup (cheap file read,
# sub-millisecond), do a one-time foreground recompile when it changes,
# then run normally. No lock files, no background processes, no source
# fallback. The recompile takes ~20s but only fires on the first firn
# invocation after a racket-version bump (rare event).

set -euo pipefail

ZO="$ZO"
MARKER="$SHARE_DIR/racket-version"
REPO="\${FIRN_REPO:-\$HOME/code/nixos-config}"
BUILD_SCRIPT="\$REPO/scripts/firn-build-bin"

# ---- racket version check ----
RACKET_VERSION="\$(racket --version 2>/dev/null | grep -oP 'v\K[0-9.]+')"
STORED_VERSION="\$(cat "\$MARKER" 2>/dev/null || echo "")"

if [ "\$RACKET_VERSION" != "\$STORED_VERSION" ]; then
  echo "firn: racket version changed (\${STORED_VERSION:-unknown} → \$RACKET_VERSION); recompiling firn + beagle libs (~20s, one-time)..." >&2
  if [ ! -x "\$BUILD_SCRIPT" ]; then
    echo "firn: build script missing at \$BUILD_SCRIPT — cannot self-heal." >&2
    exit 1
  fi
  "\$BUILD_SCRIPT" >&2
  # firn-build-bin updates the marker itself; no need to write here.
fi

# ---- run ----
exec racket "\$ZO" "\$@"
EOF
chmod +x "$WRAPPER"

ls -lh "$ZO" "$WRAPPER" | awk '{print "  ", $5, $9}'
echo "firn-build-bin: done. Make sure $BIN_DIR is on PATH."
