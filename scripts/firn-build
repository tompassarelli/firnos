#!/usr/bin/env bash
# firn-build — regenerate every *.nix from its sibling *.bnix source.
#
# Source of truth: every beagle/nix file (a .bnix file using `#lang beagle/nix`)
# anywhere under the repo. The matching .nix file is generated next to it.
#
# Files NOT covered:
#   - hardware-configuration.nix  (NixOS-generated; left as raw .nix)
#   - secrets/, dotfiles/, assets/  (non-Nix content, stays as-is)
#   - tests/, scripts/, .firn-build/   (tooling, not config)
#
# Requires the beagle Racket package to be linked.
# BEAGLE_PATH defaults to ../beagle (sibling clone).

set -euo pipefail

cd "${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

BEAGLE_PATH="${BEAGLE_PATH:-$(cd .. && pwd)/beagle}"
BEAGLE_BUILD_ALL="$BEAGLE_PATH/bin/beagle-build-all"
if [ ! -x "$BEAGLE_BUILD_ALL" ]; then
  echo "firn-build: beagle-build-all not found at $BEAGLE_BUILD_ALL" >&2
  echo "  set BEAGLE_PATH=/path/to/beagle" >&2
  exit 1
fi

# Collect stale .bnix files (missing .nix or .nix older than .bnix).
# One Racket process then builds them all (beagle-build-all --in-place),
# avoiding the per-file cold-start that dominated the old loop.
stale=()
while IFS= read -r -d '' src; do
  case "$src" in
    ./scripts/*) continue ;;
    ./tests/*) continue ;;
  esac

  nix="${src%.bnix}.nix"
  if [ -f "$nix" ] && [ "$nix" -nt "$src" ]; then
    continue
  fi
  stale+=("$src")
done < <(find . -name '*.bnix' -not -path './result*' -not -path './.direnv/*' -print0)

if [ "${#stale[@]}" -eq 0 ]; then
  echo "firn-build: nothing to rebuild."
  exit 0
fi

"$BEAGLE_BUILD_ALL" --in-place "${stale[@]}"
