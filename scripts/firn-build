#!/usr/bin/env bash
# firn-build — regenerate every *.nix from its sibling *.bnix source.
#
# Source of truth: every beagle/nix file (a .bnix file using `#lang beagle/nix`)
# anywhere under the repo. The matching .nix file is generated next to it.
#
# Files NOT covered:
#   - hardware-configuration.nix  (NixOS-generated; left as raw .nix)
#   - secrets/, dotfiles/, assets/  (non-Nix content, stays as-is)
#   - tests/, scripts/, .firn-build/   (tooling, not config)
#
# Requires the beagle Racket package to be linked.
# BEAGLE_PATH defaults to ../beagle (sibling clone).

set -euo pipefail

# Resolve repo root from this script's location so firn-build works
# regardless of cwd. FIRN_REPO env var takes precedence if set.
cd "${FIRN_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

BEAGLE_PATH="${BEAGLE_PATH:-$(cd .. && pwd)/beagle}"
BEAGLE_BUILD="$BEAGLE_PATH/bin/beagle-build"
if [ ! -x "$BEAGLE_BUILD" ]; then
  echo "firn-build: beagle-build not found at $BEAGLE_BUILD" >&2
  echo "  set BEAGLE_PATH=/path/to/beagle" >&2
  exit 1
fi

count=0
errors=0
while IFS= read -r -d '' src; do
  case "$src" in
    ./scripts/*) continue ;;
    ./tests/*) continue ;;
  esac

  nix="${src%.bnix}.nix"

  # Skip if .nix is newer than .bnix
  if [ -f "$nix" ] && [ "$nix" -nt "$src" ]; then
    continue
  fi

  if "$BEAGLE_BUILD" "$src" "$nix" >/dev/null 2>&1; then
    count=$((count + 1))
  else
    echo "firn-build: FAILED $src" >&2
    "$BEAGLE_BUILD" "$src" "$nix" 2>&1 | head -20 >&2 || true
    errors=$((errors + 1))
  fi
done < <(find . -name '*.bnix' -not -path './result*' -print0)

if [ "$errors" -gt 0 ]; then
  echo "firn-build: $count regenerated, $errors failed." >&2
  exit 1
fi

echo "firn-build: $count file(s) regenerated."
