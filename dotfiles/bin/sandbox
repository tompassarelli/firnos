#!/usr/bin/env bash
# Podman dev containers with Claude Code.
set -u

# Help
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'EOF'
sandbox — sandboxed dev containers with Claude Code

  sandbox <name> [dirs...]  create or enter a container
                            dirs are mounted as /work/<basename>
  sandbox --no-backup       skip project backup on create
  sandbox --list            list all containers
  sandbox --rm <name>       delete a container
  sandbox --rebuild         rebuild the base image
EOF
  exit 0
fi

# Rebuild base image
if [ "${1:-}" = "--rebuild" ]; then
  echo "Building claude-sandbox..."
  nix build ~/code/nixos-config#claude-sandbox \
    --out-link ~/code/nixos-config/builds/claude-sandbox \
  && echo "Loading into podman..." \
  && podman load < ~/code/nixos-config/builds/claude-sandbox \
  && echo "Done."
  exit
fi

# List containers
if [ "${1:-}" = "--list" ]; then
  podman ps -a --filter "label=makedev" --format "{{.Names}}\t{{.Status}}"
  exit
fi

# Remove container
if [ "${1:-}" = "--rm" ]; then
  podman rm -f "dev-$2"
  rm -rf "$HOME/.local/share/makedev/$2"
  exit
fi

# Parse flags
nobackup=false
args=()
for arg in "$@"; do
  if [ "$arg" = "--no-backup" ]; then
    nobackup=true
  else
    args+=("$arg")
  fi
done

if [ ${#args[@]} -eq 0 ]; then
  echo "Usage: sandbox <name> [dirs...]" >&2
  exit 1
fi

name="dev-${args[0]}"
dirs=("${args[@]:1}")

# Build image if missing
if ! podman image exists claude-sandbox:latest; then
  echo "Building claude-sandbox..."
  nix build ~/code/nixos-config#claude-sandbox \
    --out-link ~/code/nixos-config/builds/claude-sandbox \
  && echo "Loading into podman..." \
  && podman load < ~/code/nixos-config/builds/claude-sandbox \
  || exit 1
fi

# If container exists, just enter it
if podman container exists "$name"; then
  podman start -ai "$name"
  exit
fi

# Set up Claude credentials (only on first create)
datadir="$HOME/.local/share/makedev/${args[0]}"
if [ ! -d "$datadir/.claude" ]; then
  mkdir -p "$datadir"
  cp -rL --no-preserve=mode ~/.claude/ "$datadir/.claude/"
  cp ~/.claude.json "$datadir/.claude.json"
  chmod -R a+rw "$datadir/.claude" "$datadir/.claude.json"
  # Pre-trust /work so Claude Code skips the trust dialog
  python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
d.setdefault('projects', {})['/work'] = {'allowedTools': [], 'hasTrustDialogAccepted': True}
json.dump(d, open(f, 'w'), indent=2)
" "$datadir/.claude.json"
fi

# Backup projects before mounting
if [ "$nobackup" = false ]; then
  backupdir="$datadir/backups/$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$backupdir"
  if [ ${#dirs[@]} -gt 0 ]; then
    for dir in "${dirs[@]}"; do
      absdir=$(realpath "$dir")
      base=$(basename "$absdir")
      cp -r "$absdir" "$backupdir/$base"
    done
  else
    cp -r "$(pwd)" "$backupdir/$(basename "$(pwd)")"
  fi
  echo "Backup: $backupdir"
fi

# Build volume args
vols=(
  -v "$datadir/.claude:/home/dev/.claude"
  -v "$datadir/.claude.json:/home/dev/.claude.json"
)
if [ ${#dirs[@]} -gt 0 ]; then
  for dir in "${dirs[@]}"; do
    absdir=$(realpath "$dir")
    base=$(basename "$absdir")
    vols+=(-v "$absdir:/work/$base")
  done
else
  vols+=(-v "$(pwd):/work")
fi

podman create -it \
  --name "$name" \
  --label makedev \
  --userns=keep-id \
  "${vols[@]}" \
  claude-sandbox:latest
podman start -ai "$name"
