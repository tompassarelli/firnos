#!/usr/bin/env bash
# gjoa launcher + dev CLI
set -u

root="$HOME/code/gjoa"
nix_bin="$root/result/bin/gjoa"
mach_bin="$root/engine/obj-x86_64-pc-linux-gnu/dist/bin/gjoa"

# ── TEMPORARY: in-process security gate suppression ──────────────────────
# REMOVE AFTER 2026-06-02 REBUILD.
#
# The 2026-05-26 build pins Firefox 151.0.1; Mozilla shipped 151.0.2 the
# next day. The in-process gate (src/gjoa/chrome/src/security/index.ts)
# quits on any newer version. The TS file is now softened — patch-behind
# is a warn, not a quit — but that change is sealed in omni.ja and only
# takes effect after the next Sunday nix build (2026-06-02).
#
# Until then, set GJOA_ALLOW_INSECURE=1 here so daily launches don't hit
# the modal. `gjoa status` will still flag the patch-behind state.
export GJOA_ALLOW_INSECURE=1

if [ ! -d "$root" ]; then
  echo "gjoa: $root not found" >&2
  exit 1
fi

case "${1:-}" in
  # ── launch nix (release): bare = detached, -f = foreground ──────────────
  ""|-f)
    if [ ! -x "$nix_bin" ]; then
      echo "gjoa: no nix build at $nix_bin" >&2
      echo "    build it:  nix build .#gjoa --impure" >&2
      exit 1
    fi
    if [ "${1:-}" = "-f" ]; then
      shift
      exec "$nix_bin" "$@"
    else
      setsid -f "$nix_bin" </dev/null >/dev/null 2>&1
      exit 0
    fi
    ;;

  # ── launch mach (dev): bare = detached, -f = foreground ─────────────────
  dev)
    if [ ! -x "$mach_bin" ]; then
      echo "gjoa dev: no mach build at $mach_bin" >&2
      echo "    build it:  gjoa import && gjoa build  (full, 30-60 min cold)" >&2
      echo "    after that, daily rebuilds:  gjoa build faster  (~30 sec, omni.ja re-zip)" >&2
      exit 1
    fi
    if [ "${2:-}" = "-f" ]; then
      shift 2
      exec "$mach_bin" "$@"
    else
      setsid -f "$mach_bin" </dev/null >/dev/null 2>&1
      exit 0
    fi
    ;;

  # ── help ────────────────────────────────────────────────────────────────
  -h|--help|help)
    cat <<EOF
gjoa — launcher + dev CLI

Launch:
  gjoa                     nix build, detached (closes terminal)
  gjoa -f                  nix build, foreground (shows logs)
  gjoa dev                 mach build, detached
  gjoa dev -f              mach build, foreground

Status:
  gjoa status              operational dashboard (versions, CVEs, budget)

Dev loop:
  gjoa import              sync src/gjoa/ → engine/ (run before mach build)
  gjoa build [faster|…]    mach build in engine/
  gjoa sync                bundle chrome TS → symlink into mach install
  gjoa watch               auto-rebundle chrome TS on save

Tests:
  gjoa test [path|…]       bun unit tests
  gjoa test:integration    Marionette tests against mach binary
  gjoa test:integration:nix   same suite against result/bin/gjoa (nix)

Misc:
  gjoa icons               regenerate icons from assets/gjoa.svg
  gjoa clean               mach clobber (wipe objdir)
EOF
    ;;

  # ── operational dashboard ───────────────────────────────────────────────
  # Fresh pulls every call: version delta vs Mozilla/nixpkgs/Zen/LibreWolf,
  # CVE count against your pin, build state, weekly rebuild budget, what
  # command to run next. ~1-2 sec. No caching.
  status) shift; direnv exec "$root" env -C "$root" bun tools/scripts/status.ts "$@" ;;

  # ── preflight gate (mandatory before any nix/full-mach build) ───────────
  # Runs every gate mechanically. Exits non-zero if any fails. Claude must
  # show this output before proposing a rebuild — CLAUDE.md Rule #0.
  preflight) shift; direnv exec "$root" env -C "$root" bun tools/scripts/preflight.ts "$@" ;;

  # ── dev-loop verbs ──────────────────────────────────────────────────────
  build) shift; direnv exec "$root" env -C "$root/engine" ./mach build "$@" ;;
  import) direnv exec "$root" env -C "$root" bun run import ;;
  sync) direnv exec "$root" sh -c 'cd "$1" && bun run chrome:dist && bun run chrome:install' _ "$root" ;;
  watch) direnv exec "$root" env -C "$root" bun run chrome:watch ;;

  # ── tests + misc ────────────────────────────────────────────────────────
  test) shift; direnv exec "$root" env -C "$root" bun test "$@" ;;
  test:integration) direnv exec "$root" env -C "$root" bun run test:integration ;;
  test:integration:nix) direnv exec "$root" env -C "$root" bun run test:integration:nix ;;
  icons) direnv exec "$root" env -C "$root" bun run icons ;;
  clean) direnv exec "$root" env -C "$root/engine" ./mach clobber ;;

  *)
    echo "gjoa: unknown subcommand '$1'" >&2
    exit 1
    ;;
esac
