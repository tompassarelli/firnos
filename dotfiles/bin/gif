#!/usr/bin/env bash
# Record a screen region to GIF.
# Usage: gif <name> [seconds]
set -u

if [ $# -eq 0 ]; then
  echo "Usage: gif <name> [seconds]" >&2
  exit 1
fi

name="$1"
duration="${2:-10}"

geometry=$(slurp)
if [ -z "$geometry" ]; then
  echo "Error: no region selected" >&2
  exit 1
fi

echo "Recording for ${duration} seconds..."
wf-recorder -g "$geometry" -f "${name}.mp4" &
pid=$!
sleep "$duration"
kill -INT "$pid"
wait "$pid" 2>/dev/null || true

if [ ! -f "${name}.mp4" ]; then
  echo "Error: recording failed" >&2
  exit 1
fi

echo "Converting to GIF..."
ffmpeg -y -i "${name}.mp4" \
  -vf "fps=15,scale=800:-1:flags=lanczos,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse" \
  "${name}.gif" \
  && rm "${name}.mp4" \
  && echo "Created: ${name}.gif"
